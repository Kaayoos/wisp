<Window x:Class="Wisp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Wisp"
        mc:Ignorable="d"
        Title="Wisp" Height="730" Width="1200" MinHeight="640" MinWidth="1040"
        Icon="/img/WispIcon.png"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResizeWithGrip"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- Decodes clip thumbnails at gallery size instead of native resolution (keeps RAM low) -->
        <local:ThumbnailImageConverter x:Key="ThumbnailConverter"/>
        <local:TagsToListConverter x:Key="TagsToListConverter"/>
        <!-- Used to show the per-clip "Keep" pin only while auto-deletion is enabled. -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Drive the per-clip "auto-deletes in X days" countdown badge. -->
        <local:RetentionCountdownTextConverter x:Key="CountdownText"/>
        <local:RetentionCountdownBrushConverter x:Key="CountdownBrush"/>
        <local:RetentionBadgeVisibilityConverter x:Key="CountdownVis"/>

        <!-- Custom ContextMenu and MenuItem styles matching the app theme -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="#F5121414"/> <!-- Dark slate semi-transparent background -->
            <Setter Property="BorderBrush" Value="#3B494B"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Grid.IsSharedSizeScope" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <ItemsPresenter Margin="{TemplateBinding Padding}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" KeyboardNavigation.TabNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="#E2E2E2"/>
            <Setter Property="Padding" Value="8,5,12,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="4"
                                SnapsToDevicePixels="True"
                                Margin="1,1,1,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Icon"/>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                                    <ColumnDefinition Width="13" /> <!-- Submenu Arrow -->
                                </Grid.ColumnDefinitions>
                                
                                <ContentPresenter x:Name="Icon"
                                                  ContentSource="Icon"
                                                  Margin="5,0,8,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                                                  
                                <Grid x:Name="CheckMark" Margin="5,0,8,0" Visibility="Collapsed" VerticalAlignment="Center">
                                    <TextBlock Text="✓" Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="Bold"/>
                                </Grid>

                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"/>

                                <TextBlock Grid.Column="2"
                                           Text="{TemplateBinding InputGestureText}"
                                           Foreground="#B9CACB"
                                           Margin="10,0,10,0"
                                           VerticalAlignment="Center"/>

                                <Path x:Name="RightArrow"
                                      Grid.Column="3"
                                      Data="M 0,0 L 4,4 L 0,8 Z"
                                      Fill="#B9CACB"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      Visibility="Collapsed"/>

                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="true"
                                       Focusable="false"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       PopupAnimation="{DynamicResource {x:Static SystemParameters.MenuPopupAnimationKey}}"
                                       Placement="Right">
                                    <Border Background="#F5121414"
                                            BorderBrush="#3B494B"
                                            BorderThickness="1.5"
                                            CornerRadius="6"
                                            Padding="4">
                                        <ScrollViewer x:Name="SubMenuScrollViewer" CanContentScroll="true">
                                            <ItemsPresenter KeyboardNavigation.TabNavigation="Cycle"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="true">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="Icon" Value="{x:Null}">
                                <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="true">
                                <Setter TargetName="RightArrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="#5B6A6B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator" x:Key="{x:Static MenuItem.SeparatorStyleKey}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="#3B494B" Margin="4,2,4,2"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== Shared eased motion =====
             Linear animations are what make an app "feel like 15fps"; every interactive
             motion below routes through an EaseOut curve so it decelerates naturally. -->
        <Storyboard x:Key="HoverScaleIn">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.04" Duration="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.04" Duration="0:0:0.16">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="HoverScaleOut">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <!-- Flat button: takes its fill/border/foreground from the button's own properties, adds the app's
             subtle lighten-on-hover + gentle scale. Lets plain buttons match the styled ones without each
             carrying its own ControlTemplate. -->
        <Style x:Key="FlatButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6"/>
                            <Border x:Name="HoverWash" Background="#FFFFFF" Opacity="0" CornerRadius="6"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverWash" Property="Opacity" Value="0.10"/>
                                <Trigger.EnterActions><BeginStoryboard Storyboard="{StaticResource HoverScaleIn}"/></Trigger.EnterActions>
                                <Trigger.ExitActions><BeginStoryboard Storyboard="{StaticResource HoverScaleOut}"/></Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="HoverWash" Property="Opacity" Value="0.04"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrollbar Custom Styling -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#121414" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Width" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb Background="#3B494B" Margin="2,0,2,0">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="4" Background="{TemplateBinding Background}" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Width" Value="10"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Premium ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1E2020"/>
            <Setter Property="Foreground" Value="#E2E2E2"/>
            <Setter Property="BorderBrush" Value="#3B494B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6,10,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                           BorderBrush="{TemplateBinding BorderBrush}" 
                                           BorderThickness="{TemplateBinding BorderThickness}" 
                                           Background="{TemplateBinding Background}" 
                                           Grid.Column="2" 
                                           Focusable="false" 
                                           IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" 
                                           ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition />
                                                    <ColumnDefinition Width="30" />
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow" Grid.Column="1" Fill="#B9CACB" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="Border" Property="Background" Value="#282A2B" />
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="true">
                                                <Setter TargetName="Border" Property="Background" Value="#121414" />
                                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AccentBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="{TemplateBinding Padding}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" TextElement.Foreground="{TemplateBinding Foreground}" />
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="6" Margin="0,2,0,2">
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="Height" Value="95" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Editable dark ComboBox: keeps the preset dropdown but ALSO lets the user type any value
             (used for framerate/resolution so they aren't capped to a fixed list). Mirrors the
             non-editable combo's dark look; dropdown items reuse the shared ComboBoxItem style. -->
        <Style x:Key="EditableComboBoxStyle" TargetType="ComboBox">
            <Setter Property="IsEditable" Value="True"/>
            <Setter Property="StaysOpenOnEdit" Value="True"/>
            <Setter Property="Background" Value="#121414"/>
            <Setter Property="Foreground" Value="#E2E2E2"/>
            <Setter Property="BorderBrush" Value="#3B494B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="30"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="MainBorder" Grid.ColumnSpan="2" CornerRadius="6"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"/>
                            <TextBox x:Name="PART_EditableTextBox" Grid.Column="0" Style="{x:Null}"
                                     Margin="8,0,0,0" VerticalContentAlignment="Center"
                                     Background="Transparent" Foreground="{TemplateBinding Foreground}"
                                     CaretBrush="{DynamicResource AccentBrush}" BorderThickness="0"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path Fill="#B9CACB" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 4 4 L 8 0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="6" Margin="0,2,0,2">
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Simple Dark TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#121414" />
            <Setter Property="Foreground" Value="#E2E2E2" />
            <Setter Property="BorderBrush" Value="#3B494B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,5,8,5" />
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}"/>
        </Style>

        <!-- Modern CheckBox Toggle Switch Style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E2E2E2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Border x:Name="SwitchTrack" Grid.Column="0" Width="38" Height="20" Background="#1E2020" CornerRadius="10" BorderBrush="#3B494B" BorderThickness="1" SnapsToDevicePixels="True" VerticalAlignment="Center">
                                <Ellipse x:Name="SwitchThumb" Width="14" Height="14" Fill="#B9CACB" HorizontalAlignment="Left" Margin="2,0,2,0" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <Ellipse.RenderTransform>
                                        <TranslateTransform X="0"/>
                                    </Ellipse.RenderTransform>
                                </Ellipse>
                            </Border>
                            
                            <ContentPresenter Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Left" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="SwitchThumb" Property="Fill" Value="#121414"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SwitchThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="18" Duration="0:0:0.22">
                                                <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.6"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SwitchThumb" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="0" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#1E2020"/>
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#3B494B"/>
                                <Setter TargetName="SwitchThumb" Property="Fill" Value="#B9CACB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Premium Slider Style -->
        <Style TargetType="Slider">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <Track x:Name="PART_Track" Grid.Row="1">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Height="4" Background="{DynamicResource AccentBrush}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Height="4" Background="#121414" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Width="14" Height="14" VerticalAlignment="Center">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse x:Name="ellipse" Fill="{DynamicResource AccentBrush}" Stroke="#121414" StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.5"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ellipse" Property="Fill" Value="{DynamicResource AccentHoverBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar Tab Text Style -->
        <!-- Condensed, uppercase Bahnschrift turns the nav into a tactical control rail rather than a
             generic Segoe menu. Width-axis condensation (real, not synthesized) buys the airier letter
             rhythm that reads as "instrument label". -->
        <Style x:Key="SidebarTabTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B9CACB"/>
            <Setter Property="FontFamily" Value="{StaticResource FontDisplay}"/>
            <Setter Property="FontStretch" Value="Condensed"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="Selected">
                    <Setter Property="Foreground" Value="#e2e1eb"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True"/>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value=""/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Sidebar Tab Icon Style -->
        <Style x:Key="SidebarTabIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#B9CACB"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="Selected">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                </DataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True"/>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value=""/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Foreground" Value="{DynamicResource AccentHoverBrush}"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Simple Dark ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1E2020"/>
            <Setter Property="Foreground" Value="#E2E2E2"/>
            <Setter Property="Padding" Value="8,5,8,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Gd" Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="true">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Gd" Property="Background" Value="#282A2B"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Gd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="#121414"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Premium Button Style -->
        <Style x:Key="PremiumPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="#121414" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bdr" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bdr" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard Storyboard="{StaticResource HoverScaleIn}"/>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard Storyboard="{StaticResource HoverScaleOut}"/>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bdr" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Premium Secondary Button Style -->
        <Style x:Key="PremiumSecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1E2020" />
            <Setter Property="Foreground" Value="#E2E2E2" />
            <Setter Property="BorderBrush" Value="#3B494B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bdr" Property="Background" Value="#282A2B"/>
                                <Setter TargetName="Bdr" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard Storyboard="{StaticResource HoverScaleIn}"/>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard Storyboard="{StaticResource HoverScaleOut}"/>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bdr" Property="Background" Value="#121414"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Labelled pill for plugin-contributed player buttons. Content (icon + label) is built in
             code-behind (MainWindow.PluginPlayer.cs); this just styles the chrome to match the player. -->
        <Style x:Key="PlayerPluginButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="11,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#E2E2E2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#282A2B"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#121414"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ In-player transport deck (player redesign) ============ -->
        <!-- The play/pause control is the deck's primary action, so it earns the accent fill + a soft
             accent glow; every other transport control stays a quiet ghost. Icons inside bind to
             Foreground, so the button sets Foreground to dark ink to read on the accent fill. -->
        <Style x:Key="TransportPrimaryButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#0A1414"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource AccentBrush}" CornerRadius="100">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                                <Trigger.EnterActions><BeginStoryboard Storyboard="{StaticResource HoverScaleIn}"/></Trigger.EnterActions>
                                <Trigger.ExitActions><BeginStoryboard Storyboard="{StaticResource HoverScaleOut}"/></Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quiet ghost control for the secondary transport buttons (frame step, stop, mixer). Flat by
             default so the accent play button owns the deck; a circular wash + accent icon on hover.
             Buttons using this MUST NOT set a local Foreground, or the hover recolor is overridden. -->
        <Style x:Key="TransportGhostButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#B9CACB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="100">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#2B3133"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#0E1010"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ============ Export panel (export redesign) ============ -->
        <!-- The small mono eyebrow that labels each section of the export panel. One token so spacing,
             weight and contrast stay consistent across the panel instead of being re-typed per block. -->
        <Style x:Key="ExportSectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#8A9A9B"/>
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="FontSize" Value="9.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- One row of the OUTPUT spec readout (label left, mono value right). -->
        <Style x:Key="ExportSpecLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7E8C8D"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style x:Key="ExportSpecValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E2E2E2"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource FontMono}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
        </Style>

        <!-- ===== Audio-mix track controls (shared by the mixer popup + the right-click lane popup) =====
             Both the mute speaker icon and the slider draw themselves in the row's Foreground, so a track's
             controls can be tinted to match its waveform lane (mic = amber, system = accent, social = purple)
             just by setting Foreground on the control. The mute icon still greys out when checked. -->
        <Style x:Key="MixMuteToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" Background="#121414" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="6">
                            <Path x:Name="sp" Width="13" Height="13" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Data="M3,9 H7 L12,4 V20 L7,15 H3 Z" Fill="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="sp" Property="Fill" Value="#555555"/>
                                <Setter TargetName="b" Property="Background" Value="#3A1A1A"/>
                                <Setter TargetName="b" Property="BorderBrush" Value="#6B3B3B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MixSliderStyle" TargetType="Slider">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="IsMoveToPointEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center" Background="Transparent">
                            <!-- Unfilled groove -->
                            <Border Height="4" CornerRadius="2" Background="#2A3537" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Focusable="False" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Grid Background="Transparent">
                                                    <!-- Filled portion = the track's own colour -->
                                                    <Border Height="4" CornerRadius="2" VerticalAlignment="Center"
                                                            Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Slider}}"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Focusable="False" IsTabStop="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Grid Background="Transparent"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="14" Height="14" Focusable="False">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid>
                                                    <Ellipse Width="14" Height="14"
                                                             Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Slider}}"/>
                                                    <Ellipse x:Name="ring" Width="14" Height="14" Stroke="#FFFFFF" StrokeThickness="0" Opacity="0"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ring" Property="StrokeThickness" Value="2"/>
                                                        <Setter TargetName="ring" Property="Opacity" Value="0.45"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hover wash for sidebar tabs.
             This lives on its OWN element as an opacity layer, so the hover effect can never
             fight the "selected" background animation on the same property (that conflict was
             the old weird/flickery tab hover) and an opacity fade never bleeds through
             transparent-white the way a fade-to-Transparent colour animation does. -->
        <Style x:Key="SidebarTabHoverOverlay" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="#262B2D"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <!-- The overlay sits inside the tab's content area, i.e. inside the tab's Padding
                 ("12,10"), so on its own it would only be as tall as the icon/text. This negative
                 margin bleeds it back out over that padding so it fills the WHOLE row, exactly like
                 the selected-state background does. Keep this in sync with SidebarTabStyle.Padding. -->
            <Setter Property="Margin" Value="-12,-10,-12,-10"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True"/>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value=""/>
                    </MultiDataTrigger.Conditions>
                    <MultiDataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.16">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiDataTrigger.EnterActions>
                    <MultiDataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </MultiDataTrigger.ExitActions>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Selected wash for sidebar tabs. Its own accent-tinted opacity layer (same pattern as the
             hover overlay) so the active tab reads as a COMMITTED accent pill, not a hairline stripe -
             and because it paints {DynamicResource AccentSoftBrush}, it re-themes live with the accent.
             Hover and Selected are mutually exclusive (hover requires Tag=""), so the two washes never
             stack. -->
        <Style x:Key="SidebarTabSelectedOverlay" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="Margin" Value="-12,-10,-12,-10"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Border}}" Value="Selected">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Modern Premium Sidebar Tab Style -->
        <Style x:Key="SidebarTabStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10,12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <!-- Opaque base colours that match the sidebar, so nothing animates through
                 transparent-white. The left edge is a cyan accent kept at zero alpha until selected. -->
            <Setter Property="Background">
                <Setter.Value>
                    <SolidColorBrush Color="#1A1C1C"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <SolidColorBrush Color="#0000F2FF"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Style.Triggers>
                <!-- Selected: lift the background and ease in the chunky cyan accent bar. The accent WASH
                     comes from SidebarTabSelectedOverlay; this trigger handles the bar + neutral lift. -->
                <Trigger Property="Tag" Value="Selected">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="Background.Color" To="#2A3133" Duration="0:0:0.22">
                                    <ColorAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ColorAnimation.EasingFunction>
                                </ColorAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="Background.Color" To="#1A1C1C" Duration="0:0:0.22">
                                    <ColorAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ColorAnimation.EasingFunction>
                                </ColorAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#121414" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50" /> <!-- Custom Title Bar -->
                <RowDefinition Height="*" />   <!-- Client Area -->
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" /> <!-- Left Sidebar (from StitchMCP) -->
                <ColumnDefinition Width="*" />   <!-- Right Panel (Content) -->
            </Grid.ColumnDefinitions>

            <!-- ================= CUSTOM TITLE BAR ================= -->
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" 
                    Background="#121414" BorderBrush="#3B494B" BorderThickness="0,0,0,1" 
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="15,0,15,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    </StackPanel>

                    <!-- Control Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="-" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                Foreground="#B9CACB" FontSize="12" Width="30" Height="30" Margin="0,0,5,0"
                                Click="MinimizeButton_Click"/>
                        <Button x:Name="MaximizeButton" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                Foreground="#B9CACB" Width="30" Height="30" Margin="0,0,5,0"
                                Click="MaximizeButton_Click" ToolTip="Maximize">
                            <Grid Width="11" Height="11">
                                <Path x:Name="MaximizeIcon" Stretch="Uniform" Stroke="#B9CACB" StrokeThickness="1.3" Data="M0,0 H11 V11 H0 Z"/>
                                <Path x:Name="RestoreIcon" Stretch="Uniform" Visibility="Collapsed" Stroke="#B9CACB" StrokeThickness="1.3" Data="M0,3 H8 V11 H0 Z M3,3 V0 H11 V8 H8"/>
                            </Grid>
                        </Button>
                        <Button Content="✕" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                                Foreground="#B9CACB" FontSize="14" Width="30" Height="30"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ================= SIDEBAR (from StitchMCP) ================= -->
            <Border Grid.Row="1" Grid.Column="0" Background="#1A1C1C" 
                    BorderBrush="#3B494B" BorderThickness="0,0,1,0" CornerRadius="0,0,0,12">
                <Grid Margin="15,20,15,15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" /> <!-- Brand/Header -->
                        <RowDefinition Height="Auto" /> <!-- Navigation Tabs -->
                        <RowDefinition Height="*" />    <!-- Bottom controls container -->
                    </Grid.RowDefinitions>

                    <!-- Brand Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,25" HorizontalAlignment="Center">
                        <Image Source="/img/WispWordmark.png" Height="34" HorizontalAlignment="Center"
                               Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <!-- Maker attribution: subtle, plain text (not clickable) -->
                        <TextBlock Margin="0,5,0,0" HorizontalAlignment="Center" FontSize="9.5" FontFamily="{StaticResource FontMono}">
                            <Run Text="by MinimalPulse" Foreground="{DynamicResource TextMutedBrush}"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Navigation Tabs -->
                    <StackPanel x:Name="SidebarPanel" Grid.Row="1">
                        <!-- Library Tab -->
                        <Border x:Name="LibraryTab" Style="{StaticResource SidebarTabStyle}" Tag="Selected" MouseDown="LibraryTab_MouseDown">
                            <Grid>
                                <Border Style="{StaticResource SidebarTabSelectedOverlay}"/>
                                <Border Style="{StaticResource SidebarTabHoverOverlay}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="LibraryTabIcon" Text="&#xE8A9;" Style="{StaticResource SidebarTabIconStyle}"/>
                                    <TextBlock x:Name="LibraryTabText" Text="LIBRARY" Style="{StaticResource SidebarTabTextStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Favorites Tab -->
                        <Border x:Name="FavoritesTab" Style="{StaticResource SidebarTabStyle}" Tag="" MouseDown="FavoritesTab_MouseDown">
                            <Grid>
                                <Border Style="{StaticResource SidebarTabSelectedOverlay}"/>
                                <Border Style="{StaticResource SidebarTabHoverOverlay}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="FavoritesTabIcon" Text="&#xE734;" Style="{StaticResource SidebarTabIconStyle}"/>
                                    <TextBlock x:Name="FavoritesTabText" Text="FAVORITES" Style="{StaticResource SidebarTabTextStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Settings Tab -->
                        <Border x:Name="SettingsTab" Style="{StaticResource SidebarTabStyle}" Tag="" MouseDown="SettingsTab_MouseDown">
                            <Grid>
                                <Border Style="{StaticResource SidebarTabSelectedOverlay}"/>
                                <Border Style="{StaticResource SidebarTabHoverOverlay}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="SettingsTabIcon" Text="&#xE713;" Style="{StaticResource SidebarTabIconStyle}"/>
                                    <TextBlock x:Name="SettingsTabText" Text="SETTINGS" Style="{StaticResource SidebarTabTextStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Storage Tab -->
                        <Border x:Name="StorageTab" Style="{StaticResource SidebarTabStyle}" Tag="" MouseDown="StorageTab_MouseDown">
                            <Grid>
                                <Border Style="{StaticResource SidebarTabSelectedOverlay}"/>
                                <Border Style="{StaticResource SidebarTabHoverOverlay}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="StorageTabIcon" Text="&#xEDA2;" Style="{StaticResource SidebarTabIconStyle}"/>
                                    <TextBlock x:Name="StorageTabText" Text="STORAGE" Style="{StaticResource SidebarTabTextStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Plugins Tab -->
                        <Border x:Name="PluginsTab" Style="{StaticResource SidebarTabStyle}" Tag="" MouseDown="PluginsTab_MouseDown">
                            <Grid>
                                <Border Style="{StaticResource SidebarTabSelectedOverlay}"/>
                                <Border Style="{StaticResource SidebarTabHoverOverlay}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="PluginsTabIcon" Text="&#xEA86;" Style="{StaticResource SidebarTabIconStyle}"/>
                                    <TextBlock x:Name="PluginsTabText" Text="PLUGINS" Style="{StaticResource SidebarTabTextStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Support Tab -->
                        <Border x:Name="SupportTab" Style="{StaticResource SidebarTabStyle}" Tag="" MouseDown="SupportTab_MouseDown">
                            <Grid>
                                <Border Style="{StaticResource SidebarTabSelectedOverlay}"/>
                                <Border Style="{StaticResource SidebarTabHoverOverlay}"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="SupportTabIcon" Text="&#xE8F2;" Style="{StaticResource SidebarTabIconStyle}"/>
                                    <TextBlock x:Name="SupportTabText" Text="SUPPORT" Style="{StaticResource SidebarTabTextStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- ===== CAPTURE CONSOLE (the app's heartbeat) =====
                         The three loose status cards are fused into one instrument panel. Its top strip
                         carries a status light that BREATHES while the buffer is live and goes dim when
                         paused (driven from UpdateRecordingIndicator), so "Wisp is catching" reads at a
                         glance - the single most important state in the app. CaptureTargetText /
                         CaptureProcessText / HotkeyBadgeBorder / HotkeyBadge keep their names so the
                         capture-polling + hotkey-rebind code drives them unchanged. -->
                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom">
                        <Border Background="{DynamicResource SurfaceRaisedBrush}" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1" Margin="0,0,0,12">
                            <StackPanel>
                                <!-- Live status strip -->
                                <Border CornerRadius="9,9,0,0" Background="{DynamicResource AccentSoftBrush}" Padding="13,8">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse x:Name="BufferStatusDot" Width="9" Height="9" VerticalAlignment="Center"
                                                 Fill="{DynamicResource AccentBrush}"/>
                                        <TextBlock x:Name="BufferStatusText" Text="REPLAY ON" Margin="9,0,0,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource AccentBrush}" FontFamily="{StaticResource FontDisplay}"
                                                   FontStretch="Condensed" FontWeight="Bold" FontSize="14"/>
                                    </StackPanel>
                                </Border>

                                <!-- Capturing target -->
                                <StackPanel Margin="13,10,13,11">
                                    <TextBlock Text="CAPTURING TARGET" Foreground="{DynamicResource TextMutedBrush}" FontSize="9.5" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,5"/>
                                    <TextBlock x:Name="CaptureTargetText" Text="Desktop" Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontFamily="{StaticResource FontDisplay}" FontStretch="Condensed" FontWeight="SemiBold"
                                               FontSize="17" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="CaptureProcessText" Text="explorer.exe" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" FontFamily="{StaticResource FontMono}" TextTrimming="CharacterEllipsis" Margin="0,3,0,0"/>
                                </StackPanel>

                                <Border Height="1" Background="#2E3739"/>

                                <!-- Hotkey to save (click anywhere to rebind) -->
                                <Border x:Name="HotkeyBadgeBorder" CornerRadius="0,0,9,9" Cursor="Hand" MouseDown="HotkeyBadgeBorder_MouseDown" Padding="13,10,13,12" ToolTip="Click to rebind your save hotkey">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#12FFFFFF"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="HOTKEY TO SAVE" Foreground="{DynamicResource TextMutedBrush}" FontSize="9.5" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                            <!-- Accent keycap: the hotkey reads like a physical key on the instrument -->
                                            <Border Background="{DynamicResource AppWellBrush}" BorderBrush="{DynamicResource BorderStrongBrush}" BorderThickness="1" CornerRadius="6" Padding="10,4" HorizontalAlignment="Left">
                                                <TextBlock x:Name="HotkeyBadge" Text="Alt + K" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontFamily="{StaticResource FontMono}" FontSize="14"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextMutedBrush}" FontSize="14" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Arm / disarm Instant Replay (the rolling capture) -->
                        <Button x:Name="ToggleRecBtn" Content="Stop Replay" Height="36" Margin="0,0,0,14" Style="{StaticResource PremiumSecondaryButtonStyle}" Click="ToggleRecBtn_Click" />

                        <!-- Footer -->
                        <Border BorderBrush="#2E3739" BorderThickness="0,1,0,0" Padding="2,10,2,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="WISP" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" FontWeight="Bold" FontFamily="{StaticResource FontDisplay}" FontStretch="Condensed" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding AppVersionText, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=v{0}}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ================= RIGHT PANEL (CONTENT AREA) ================= -->
            <Grid Grid.Row="1" Grid.Column="1" Background="#121414">
                <Grid.RowDefinitions>
                    <RowDefinition Height="80" /> <!-- Top Header / Toolbar -->
                    <RowDefinition Height="*" />  <!-- Switchable Content Panel -->
                </Grid.RowDefinitions>

                <!-- Top Header Bar -->
                <Border Grid.Row="0" BorderBrush="#3B494B" BorderThickness="0,0,0,1" Padding="20,10,20,10">
                    <Grid>
                        <!-- Library Header Panel -->
                        <Grid x:Name="LibraryHeader" Visibility="Visible">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />    <!-- Title (flexes, never overlaps the controls) -->
                                <ColumnDefinition Width="Auto" /> <!-- Search -->
                                <ColumnDefinition Width="Auto" /> <!-- Filters / Sort -->
                                <ColumnDefinition Width="Auto" /> <!-- Refresh -->
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                <TextBlock x:Name="HeaderTitleText" Text="Recent Captures" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource FontDisplay}" FontWeight="SemiBold" FontSize="30" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="HeaderSubtitleText" Text="Your latest highlights and recordings." Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,1,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- Search Input -->
                            <Border x:Name="SearchBorder" Grid.Column="1" Background="#1E2020" CornerRadius="8" BorderThickness="1" Height="36" Width="220" VerticalAlignment="Center" Margin="0,0,12,0">
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#3B494B"/>
                                </Border.BorderBrush>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"/>
                                    <TextBox Grid.Column="1" x:Name="SearchBox" Background="Transparent" BorderThickness="0" Foreground="#E2E2E2" 
                                             VerticalAlignment="Center" Margin="2,0,5,0" CaretBrush="{DynamicResource AccentBrush}" FontSize="11"
                                             TextChanged="SearchBox_TextChanged"/>
                                    <Border Grid.Column="2" Background="#121414" CornerRadius="4" BorderBrush="#3B494B" BorderThickness="1" Margin="0,0,6,0" VerticalAlignment="Center" Padding="5,2,5,2">
                                        <TextBlock Text="Ctrl K" Foreground="#B9CACB" FontSize="8" FontWeight="Bold" FontFamily="{StaticResource FontMono}"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- Filters / Sort. Labels dropped on purpose: each combo already names itself
                                 ("All Games" / "All Tags" / "Newest First"), so the bare controls read
                                 cleaner and free the row for the commanding title. -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                <ComboBox x:Name="GameFilterCombo" Width="128" Height="36" Background="#1E2020" Foreground="#E2E2E2" BorderBrush="#3B494B"
                                          Margin="0,0,8,0" SelectionChanged="GameFilterCombo_SelectionChanged" ToolTip="Filter by game"/>
                                <ComboBox x:Name="TagFilterCombo" Width="112" Height="36" Background="#1E2020" Foreground="#E2E2E2" BorderBrush="#3B494B"
                                          Margin="0,0,8,0" SelectionChanged="TagFilterCombo_SelectionChanged" ToolTip="Filter by tag"/>
                                <ComboBox x:Name="SortCombo" Width="124" Height="36" Background="#1E2020" Foreground="#E2E2E2" BorderBrush="#3B494B"
                                          SelectionChanged="SortCombo_SelectionChanged" SelectedIndex="0" ToolTip="Sort order">
                                    <ComboBoxItem Content="Newest First"/>
                                    <ComboBoxItem Content="Oldest First"/>
                                    <ComboBoxItem Content="Longest First"/>
                                    <ComboBoxItem Content="Shortest First"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Refresh Button -->
                            <Button x:Name="RefreshButton" Grid.Column="3" Width="36" Height="36" VerticalAlignment="Center" Background="#1E2020" Foreground="#E2E2E2"
                                    BorderBrush="#3B494B" BorderThickness="1" Click="RefreshButton_Click" ToolTip="Refresh Clip Grid" Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="rb" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="rb" Property="Background" Value="#282A2B"/>
                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <TextBlock x:Name="RefreshIcon" Text="↻" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"
                                           RenderTransformOrigin="0.5,0.5" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="RefreshIconRotate" Angle="0"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Button>
                        </Grid>

                        <!-- Settings Header Panel -->
                        <Grid x:Name="SettingsHeader" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Settings" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource FontDisplay}" FontWeight="SemiBold" FontSize="30"/>
                                <TextBlock Text="Configure your capture environment and performance parameters." Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Plugins Header Panel -->
                        <Grid x:Name="PluginsHeader" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Plugins" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource FontDisplay}" FontWeight="SemiBold" FontSize="30"/>
                                <TextBlock Text="Extend Wisp with community plugins. Only enable plugins you trust." Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Storage Header Panel -->
                        <Grid x:Name="StorageHeader" Visibility="Collapsed">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Storage" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource FontDisplay}" FontWeight="SemiBold" FontSize="30"/>
                                <TextBlock Text="Library stats, disk usage, and automatic clip cleanup." Foreground="{DynamicResource TextMutedBrush}" FontSize="12" Margin="0,1,0,0"/>
                            </StackPanel>
                        </Grid>

                    </Grid>
                </Border>

                <!-- Switchable Content Switcher -->
                <Grid x:Name="MainContentContainer" Grid.Row="1">
                    <!-- Library Grid View -->
                    <Grid x:Name="ClipLibraryGrid" Visibility="Visible" Margin="20,15,20,15">
                        <!-- Clip Cards Grid list -->
                        <ListBox x:Name="ClipsListBox" Background="Transparent" BorderThickness="0" 
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  SelectionMode="Extended"
                                  SelectionChanged="ClipsListBox_SelectionChanged"
                                  MouseDoubleClick="ClipsListBox_MouseDoubleClick">
                            <!-- Left-align the wrapped card block so cards always fill from the left edge.
                                 Centering looked balanced on full rows but stranded a lone clip in the
                                 middle of the page when only a few clips existed. -->
                            <ListBox.Template>
                                <ControlTemplate TargetType="ListBox">
                                    <ScrollViewer Focusable="False" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter HorizontalAlignment="Stretch"/>
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ListBox.Template>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="{Binding Path=ClipItemWidth, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="6"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="OuterBorder" BorderBrush="Transparent" BorderThickness="2" CornerRadius="10" Padding="4" Margin="2" Background="Transparent" SnapsToDevicePixels="True" HorizontalAlignment="Stretch">
                                                    <ContentPresenter HorizontalAlignment="Stretch"/>
                                                 </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter TargetName="OuterBorder" Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <!-- Card Base -->
                                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" MinWidth="220" Height="198" HorizontalAlignment="Stretch" ClipToBounds="True" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                        <Trigger.EnterActions>
                                                            <BeginStoryboard Storyboard="{StaticResource HoverScaleIn}"/>
                                                        </Trigger.EnterActions>
                                                        <Trigger.ExitActions>
                                                            <BeginStoryboard Storyboard="{StaticResource HoverScaleOut}"/>
                                                        </Trigger.ExitActions>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="120" /> <!-- Thumbnail -->
                                                <RowDefinition Height="*" />   <!-- Info -->
                                            </Grid.RowDefinitions>

                                            <!-- Thumbnail and Duration Overlay -->
                                            <Grid Grid.Row="0" Background="#121414">
                                                <Image Source="{Binding ThumbnailPath, Converter={StaticResource ThumbnailConverter}, ConverterParameter=360}" Stretch="UniformToFill"/>
                                                
                                                <!-- Duration Badge -->
                                                <Border Background="#B3121414" CornerRadius="4" Padding="6,2,6,2" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="8" BorderBrush="#3B494B" BorderThickness="1">
                                                    <TextBlock Text="{Binding FormattedDuration}" Foreground="#E2E2E2" FontSize="10" FontWeight="Bold" FontFamily="{StaticResource FontMono}"/>
                                                </Border>

                                                <!-- Top-left stack: game tag, then (when the age limit is on) the
                                                     "auto-deletes in X days" countdown badge. -->
                                                <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="8">
                                                    <!-- Game Tag (hidden when no game was detected) -->
                                                    <Border CornerRadius="4" Padding="6,2,6,2" HorizontalAlignment="Left" Background="{DynamicResource AccentBrush}" MaxWidth="160">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding GameName}" Value="">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <TextBlock Text="{Binding GameName}" Foreground="#121414" FontSize="9" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                                    </Border>

                                                    <!-- Auto-deletion countdown badge. Visible only while the age limit + countdown
                                                         toggle are on and the clip isn't kept; amber when deletion is imminent. -->
                                                    <Border CornerRadius="4" Padding="6,2,7,2" HorizontalAlignment="Left" Margin="0,5,0,0"
                                                            Background="#CC101414" BorderThickness="1"
                                                            ToolTip="This clip is auto-deleted when it passes the age limit. Keep it (pin) or turn the countdown off in Storage.">
                                                        <Border.BorderBrush>
                                                            <MultiBinding Converter="{StaticResource CountdownBrush}">
                                                                <Binding Path="CreatedAt"/>
                                                                <Binding Path="RetentionDays" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                            </MultiBinding>
                                                        </Border.BorderBrush>
                                                        <Border.Visibility>
                                                            <MultiBinding Converter="{StaticResource CountdownVis}">
                                                                <Binding Path="RetentionCountdownActive" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                <Binding Path="IsKept"/>
                                                            </MultiBinding>
                                                        </Border.Visibility>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Path Width="9" Height="9" Stretch="Uniform" StrokeThickness="1.6" Fill="Transparent"
                                                                  StrokeLineJoin="Round" StrokeEndLineCap="Round" VerticalAlignment="Center" Margin="0,0,4,0"
                                                                  Data="M3,12 A9,9 0 1 1 21,12 A9,9 0 1 1 3,12 M12,7 L12,12 L15.5,13.8">
                                                                <Path.Stroke>
                                                                    <MultiBinding Converter="{StaticResource CountdownBrush}">
                                                                        <Binding Path="CreatedAt"/>
                                                                        <Binding Path="RetentionDays" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    </MultiBinding>
                                                                </Path.Stroke>
                                                            </Path>
                                                            <TextBlock FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center">
                                                                <TextBlock.Text>
                                                                    <MultiBinding Converter="{StaticResource CountdownText}">
                                                                        <Binding Path="CreatedAt"/>
                                                                        <Binding Path="RetentionDays" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                                <TextBlock.Foreground>
                                                                    <MultiBinding Converter="{StaticResource CountdownBrush}">
                                                                        <Binding Path="CreatedAt"/>
                                                                        <Binding Path="RetentionDays" RelativeSource="{RelativeSource AncestorType=Window}"/>
                                                                    </MultiBinding>
                                                                </TextBlock.Foreground>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Chain Badge (bottom-left): marks a stitched multi-moment clip. The little
                                                     segment pips echo how many moments were chained, so the card reads as
                                                     "made of several clips" at a glance. Hidden for ordinary single clips. -->
                                                <Border VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="8" CornerRadius="4"
                                                        Padding="6,2,7,2" Background="#E6101414" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                                                        ToolTip="Chained clip - several moments stitched into one">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsChained}" Value="False">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="10" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding ChainCountLabel}" Foreground="{DynamicResource AccentBrush}" FontSize="10" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="4,0,6,0" VerticalAlignment="Center"/>
                                                        <ItemsControl ItemsSource="{Binding ChainMarkerOffsets}" VerticalAlignment="Center">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Rectangle Width="4" Height="8" RadiusX="1" RadiusY="1" Margin="1,0,0,0" Fill="{DynamicResource AccentBrush}"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Hover Play Overlay -->
                                                <Border x:Name="PlayOverlay" Background="#90121414" Opacity="0">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border, AncestorLevel=1}, Path=IsMouseOver}" Value="True">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18">
                                                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                    <DataTrigger.ExitActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.22">
                                                                                    <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                                                </DoubleAnimation>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.ExitActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <!-- Play Button -->
                                                        <Button x:Name="PlayCardBtn" Width="42" Height="42" Margin="0,0,12,0" Cursor="Hand" Click="PlayCardBtn_Click" ToolTip="Play Clip">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Grid x:Name="BtnGrid" RenderTransformOrigin="0.5,0.5">
                                                                                    <Grid.RenderTransform>
                                                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                                    </Grid.RenderTransform>
                                                                                    <Ellipse x:Name="Circle" Fill="{DynamicResource AccentBrush}" Opacity="0.95"/>
                                                                                    <Path Data="M 0,0 L 0,14 L 10,7 Z" Fill="#121414" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0,0,0" Stretch="Fill" Width="10" Height="14"/>
                                                                                </Grid>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Circle" Property="Fill" Value="{DynamicResource AccentHoverBrush}"/>
                                                                                        <Trigger.EnterActions>
                                                                                            <BeginStoryboard>
                                                                                                <Storyboard>
                                                                                                    <DoubleAnimation Storyboard.TargetName="BtnGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.15" Duration="0:0:0.16"><DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                                                                    <DoubleAnimation Storyboard.TargetName="BtnGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.15" Duration="0:0:0.16"><DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                                                                </Storyboard>
                                                                                            </BeginStoryboard>
                                                                                        </Trigger.EnterActions>
                                                                                        <Trigger.ExitActions>
                                                                                            <BeginStoryboard>
                                                                                                <Storyboard>
                                                                                                    <DoubleAnimation Storyboard.TargetName="BtnGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                                                                    <DoubleAnimation Storyboard.TargetName="BtnGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                                                                </Storyboard>
                                                                                            </BeginStoryboard>
                                                                                        </Trigger.ExitActions>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>

                                                        <!-- Delete Button -->
                                                        <Button x:Name="DeleteCardBtn" Width="42" Height="42" Cursor="Hand" Click="DeleteCardBtn_Click" ToolTip="Delete Clip">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Grid x:Name="BtnGrid" RenderTransformOrigin="0.5,0.5">
                                                                                    <Grid.RenderTransform>
                                                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                                    </Grid.RenderTransform>
                                                                                    <Ellipse x:Name="Circle" Fill="#1E2020" Stroke="#FF3B30" StrokeThickness="1.5" Opacity="0.95"/>
                                                                                    <Path x:Name="TrashIcon" Data="M 19,4 H 15.5 L 14.5,3 H 9.5 L 8.5,4 H 5 V 6 H 19 M 6,19 A 2,2 0 0,0 8,21 H 16 A 2,2 0 0,0 18,19 V 7 H 6 V 19 Z" Fill="#FF3B30" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" Width="16" Height="16"/>
                                                                                </Grid>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Circle" Property="Fill" Value="#FF3B30"/>
                                                                                        <Setter TargetName="TrashIcon" Property="Fill" Value="#FFFFFF"/>
                                                                                        <Trigger.EnterActions>
                                                                                            <BeginStoryboard>
                                                                                                <Storyboard>
                                                                                                    <DoubleAnimation Storyboard.TargetName="BtnGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.15" Duration="0:0:0.16"><DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                                                                    <DoubleAnimation Storyboard.TargetName="BtnGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.15" Duration="0:0:0.16"><DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.5"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                                                                </Storyboard>
                                                                                            </BeginStoryboard>
                                                                                        </Trigger.EnterActions>
                                                                                        <Trigger.ExitActions>
                                                                                            <BeginStoryboard>
                                                                                                <Storyboard>
                                                                                                    <DoubleAnimation Storyboard.TargetName="BtnGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                                                                    <DoubleAnimation Storyboard.TargetName="BtnGrid" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"><DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction></DoubleAnimation>
                                                                                                </Storyboard>
                                                                                            </BeginStoryboard>
                                                                                        </Trigger.ExitActions>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Keep pin: excludes a clip from auto-deletion. Quiet by default - it only
                                                     appears while auto-deletion is on AND either the clip is kept (filled pin =
                                                     status) or the card is hovered (outline pin = the keep/unkeep affordance).
                                                     The full toggle also lives in the right-click menu. -->
                                                <Button x:Name="ProtectCardBtn" Click="ProtectCardBtn_Click" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,8,40,8" Width="26" Height="26" Cursor="Hand"
                                                        ToolTip="Keep this clip (exclude it from auto-deletion). Favorites are always kept.">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding AutoDeletionActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                                        <Condition Binding="{Binding IsKept}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding AutoDeletionActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True"/>
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=Border, AncestorLevel=1}, Path=IsMouseOver}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="#99121414" CornerRadius="13">
                                                                <Path Width="14" Height="14" Stretch="Uniform" StrokeThickness="1.4" StrokeLineJoin="Round"
                                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                      Data="M12,2 C8.13,2 5,5.13 5,9 C5,14.25 12,22 12,22 C12,22 19,14.25 19,9 C19,5.13 15.87,2 12,2 Z M12,11.5 C10.62,11.5 9.5,10.38 9.5,9 C9.5,7.62 10.62,6.5 12,6.5 C13.38,6.5 14.5,7.62 14.5,9 C14.5,10.38 13.38,11.5 12,11.5 Z">
                                                                    <Path.Style>
                                                                        <Style TargetType="Path">
                                                                            <Setter Property="Fill" Value="Transparent"/>
                                                                            <Setter Property="Stroke" Value="#E2E2E2"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsKept}" Value="True">
                                                                                    <Setter Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                                                    <Setter Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Path.Style>
                                                                </Path>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>

                                                <!-- Favorite (star) toggle -->
                                                <Button x:Name="FavoriteCardBtn" Click="FavoriteCardBtn_Click" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="8" Width="26" Height="26" Cursor="Hand" ToolTip="Favorite">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="#99121414" CornerRadius="13">
                                                                <Path Width="14" Height="14" Stretch="Uniform" StrokeThickness="1.4"
                                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                      Data="M12,2 L15.09,8.26 L22,9.27 L17,14.14 L18.18,21.02 L12,17.77 L5.82,21.02 L7,14.14 L2,9.27 L8.91,8.26 Z">
                                                                    <Path.Style>
                                                                        <Style TargetType="Path">
                                                                            <Setter Property="Fill" Value="Transparent"/>
                                                                            <Setter Property="Stroke" Value="#E2E2E2"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                                    <Setter Property="Fill" Value="#FFC53D"/>
                                                                                    <Setter Property="Stroke" Value="#FFC53D"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Path.Style>
                                                                </Path>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>

                                            <!-- Info Area -->
                                            <Grid Grid.Row="1" Margin="10,8,10,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/> <!-- Filename -->
                                                    <RowDefinition Height="Auto"/> <!-- Tags -->
                                                    <RowDefinition Height="Auto"/> <!-- Details -->
                                                </Grid.RowDefinitions>

                                                <TextBlock Grid.Row="0" Text="{Binding Filename}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="Bold" FontSize="12.5"
                                                           TextTrimming="CharacterEllipsis" ToolTip="{Binding Filename}"/>
                                                
                                                <ItemsControl Grid.Row="1" ItemsSource="{Binding TagList}" Margin="0,4,0,0">
                                                     <ItemsControl.ItemsPanel>
                                                         <ItemsPanelTemplate>
                                                             <WrapPanel Orientation="Horizontal" />
                                                         </ItemsPanelTemplate>
                                                     </ItemsControl.ItemsPanel>
                                                     <ItemsControl.ItemTemplate>
                                                         <DataTemplate>
                                                             <Border Background="{Binding BackgroundBrush}" BorderBrush="{Binding BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2,6,2" Margin="0,0,4,2">
                                                                 <TextBlock Text="{Binding Name}" Foreground="{Binding TextBrush}" FontSize="9" FontWeight="Bold"/>
                                                             </Border>
                                                         </DataTemplate>
                                                     </ItemsControl.ItemTemplate>
                                                 </ItemsControl>

                                                <Grid Grid.Row="2" Margin="0,5,0,0">
                                                    <TextBlock Text="{Binding FormattedDate}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" HorizontalAlignment="Left" FontFamily="{StaticResource FontMono}"/>
                                                    <TextBlock Text="{Binding FormattedSize}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" HorizontalAlignment="Right" FontFamily="{StaticResource FontMono}"/>
                                                </Grid>
                                            </Grid>
                                        </Grid>
                                        
                                        <Border.ContextMenu>
                                            <ContextMenu Opened="ClipContextMenu_Opened">
                                                <MenuItem Header="Play" Click="PlayContext_Click">
                                                    <MenuItem.Icon><TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#B9CACB"/></MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem x:Name="AssignTagsMenuItem" Header="Assign tags">
                                                    <MenuItem.Icon><TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#B9CACB"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Rename" Click="RenameContext_Click">
                                                    <MenuItem.Icon><TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#B9CACB"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Delete" Click="DeleteContext_Click">
                                                    <MenuItem.Icon><TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#FF6B6B"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Keep this clip" Tag="protect" Click="ProtectContext_Click">
                                                    <MenuItem.Icon><TextBlock Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource AccentBrush}"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Open folder" Click="OpenFolderContext_Click">
                                                    <MenuItem.Icon><TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#B9CACB"/></MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Copy file path" Click="CopyPathContext_Click">
                                                    <MenuItem.Icon><TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#B9CACB"/></MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Empty State Message -->
                        <Grid x:Name="EmptyStateGrid" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0">
                            <StackPanel HorizontalAlignment="Center" MaxWidth="400">
                                <Border Width="78" Height="78" CornerRadius="39" Background="{DynamicResource AccentSoftBrush}" HorizontalAlignment="Center" Margin="0,0,0,22">
                                    <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="34" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                                </Border>
                                <TextBlock Text="NOTHING CAPTURED YET" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource FontDisplay}" FontStretch="Condensed" FontWeight="Bold" FontSize="27" HorizontalAlignment="Center"/>
                                <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="12.5" Margin="0,9,0,0" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                                           Text="Jump into a game and hit your save hotkey - Wisp keeps the last moments of screen and audio ready, so they're yours the instant something happens."/>
                            </StackPanel>
                        </Grid>

                        <!-- Contextual Bulk Action Bar -->
                        <Border x:Name="BulkActionBar" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20"
                                Background="#1A1E1F" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="8"
                                Padding="16,8" Visibility="Collapsed" Panel.ZIndex="50">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.5" BlurRadius="20" ShadowDepth="4"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="BulkSelectionCountText" Text="2 selected" Foreground="#E2E2E2" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                
                                <Button x:Name="BulkFavoriteBtn" Content="Favorite" Width="80" Height="28" Background="#2A3031" Foreground="#E2E2E2" Margin="0,0,8,0" Click="BulkFavoriteBtn_Click" Style="{StaticResource FlatButtonStyle}"/>
                                <Button x:Name="BulkDeleteBtn" Content="Delete" Width="80" Height="28" Background="#3E1A1A" Foreground="#FF4D4D" Margin="0,0,16,0" Click="BulkDeleteBtn_Click" Style="{StaticResource FlatButtonStyle}"/>

                                <Button x:Name="BulkCancelBtn" Content="Cancel" Width="60" Height="28" Background="Transparent" Foreground="#B9CACB" Click="BulkCancelBtn_Click" Style="{StaticResource FlatButtonStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Plugins Management View -->
                    <Grid x:Name="PluginsGrid" Visibility="Collapsed" Margin="20,15,20,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Top action bar -->
                        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16,12" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#FFD54F" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="Only enable plugins you trust - they run with full access to Wisp." Foreground="{DynamicResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button x:Name="OpenPluginsFolderBtn" Grid.Column="1" Content="Open Folder" Height="30" Padding="12,0" Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Click="OpenPluginsFolderBtn_Click" Style="{StaticResource FlatButtonStyle}" Margin="0,0,8,0"/>
                                <Button x:Name="ReloadPluginsBtn" Grid.Column="2" Content="Reload" Height="30" Padding="12,0" Background="Transparent" Foreground="{DynamicResource AccentBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" Click="ReloadPluginsBtn_Click" Style="{StaticResource FlatButtonStyle}"/>
                            </Grid>
                        </Border>

                        <!-- Plugin list -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="PluginsPanel" MaxWidth="700" HorizontalAlignment="Center">
                                <!-- Cards are populated in code-behind -->
                                <ItemsControl x:Name="PluginsItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,10">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding VersionLabel}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding AuthorLabel}" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,0,0,4"/>
                                                        <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                        <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="Bold" FontFamily="{StaticResource FontMono}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsEnabled}" Value="True">
                                                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Width="32" Height="32" Background="Transparent" BorderThickness="0" Margin="0,0,10,0" Tag="{Binding Id}" Click="PluginSettingsBtn_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasSettings}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="#282A2B"/>
                                                                        </Trigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                        <CheckBox VerticalAlignment="Center" IsChecked="{Binding IsEnabled}" Tag="{Binding Id}" Checked="PluginToggle_Changed" Unchecked="PluginToggle_Changed" Style="{DynamicResource ToggleSwitchStyle}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Empty state -->
                                <Border x:Name="PluginsEmptyState" Visibility="Collapsed" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="40" HorizontalAlignment="Center">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="&#xEA86;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource TextMutedBrush}" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                        <TextBlock Text="No plugins installed" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                        <TextBlock Text="Drop a plugin folder into the plugins directory and click Reload." Foreground="{DynamicResource TextMutedBrush}" FontSize="11" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- Integrated Settings View -->
                    <Grid x:Name="SettingsGrid" Visibility="Collapsed" Margin="20,15,20,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="SettingsStackPanel" MaxWidth="700" HorizontalAlignment="Center" Margin="0,0,0,20">
                                
                                <!-- Appearance Section -->
                                <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <TextBlock Text="&#xE790;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Appearance" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock Text="THEME" Foreground="{DynamicResource TextMutedBrush}" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,10"/>
                                        <!-- Full themes (built-in + plugin), populated in code from ThemeManager.GetThemes() -->
                                        <WrapPanel x:Name="ThemePanel" Margin="0,0,0,16"/>

                                        <TextBlock Text="ACCENT COLOR" Foreground="{DynamicResource TextMutedBrush}" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,10"/>

                                        <!-- Curated preset swatches (populated in code from ThemeManager.Presets) -->
                                        <WrapPanel x:Name="PresetSwatchPanel" Margin="0,0,0,14"/>

                                        <!-- Custom color: hue slider + hex entry + live preview -->
                                        <TextBlock Text="CUSTOM" Foreground="{DynamicResource TextMutedBrush}" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider x:Name="CustomHueSlider" Grid.Column="0" Minimum="0" Maximum="360" Value="180" VerticalAlignment="Center" ValueChanged="CustomHueSlider_ValueChanged" Margin="0,0,12,0"/>
                                            <Border Grid.Column="1" Width="92" Height="32" Background="{DynamicResource AppBackgroundBrush}" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" CornerRadius="6" Margin="0,0,10,0">
                                                <TextBox x:Name="CustomHexBox" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" HorizontalContentAlignment="Center" CaretBrush="{DynamicResource AccentBrush}" FontFamily="{StaticResource FontMono}" FontSize="12" MaxLength="7" TextChanged="CustomHexBox_TextChanged"/>
                                            </Border>
                                            <Border Grid.Column="2" x:Name="CustomPreviewSwatch" Width="32" Height="32" CornerRadius="6" Background="{DynamicResource AccentBrush}" BorderBrush="{DynamicResource TextPrimaryBrush}" BorderThickness="1"/>
                                        </Grid>
                                        <TextBlock Text="Pick a preset, drag the hue slider, or type a hex code - your accent applies everywhere instantly." Foreground="{DynamicResource TextMutedBrush}" FontSize="10" Margin="0,8,0,0" TextWrapping="Wrap"/>

                                        <!-- Custom Target Cursor Toggle -->
                                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0" Visibility="Collapsed">
                                            <CheckBox x:Name="TargetCursorCheck" Content="Enable Target Cursor" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" Cursor="Hand" Checked="TargetCursorCheck_Changed" Unchecked="TargetCursorCheck_Changed"/>
                                            <TextBlock Text="(Experimental: Snappy geometric cursor that hides the native pointer)" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- General Settings Section -->
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="General Settings" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <!-- Capture Folder Selector -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Text="CAPTURE OUTPUT FOLDER" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="OutputFolderTextBox" Grid.Column="0" Height="32" Background="#121414" Foreground="#E2E2E2" BorderBrush="#3B494B" BorderThickness="1" VerticalContentAlignment="Center" Padding="8,0,8,0" FontSize="11" IsReadOnly="True"/>
                                                <Button x:Name="BrowseButton" Grid.Column="1" Content="Browse" Width="75" Height="32" Margin="10,0,0,0" Background="#3B494B" Foreground="#E2E2E2" BorderBrush="#3B494B" BorderThickness="1" Click="BrowseButton_Click" Cursor="Hand" RenderTransformOrigin="0.5,0.5">
                                                    <Button.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Button.RenderTransform>
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="Bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bdr" Property="Background" Value="#4C5E60"/>
                                                                                <Trigger.EnterActions>
                                                                                    <BeginStoryboard Storyboard="{StaticResource HoverScaleIn}"/>
                                                                                </Trigger.EnterActions>
                                                                                <Trigger.ExitActions>
                                                                                    <BeginStoryboard Storyboard="{StaticResource HoverScaleOut}"/>
                                                                                </Trigger.ExitActions>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Grid>

                                        <!-- Global Capture Shortcut Selection -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
                                                <TextBlock Text="GLOBAL CAPTURE SHORTCUT" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Press this shortcut globally to capture game clips." Foreground="#B9CACB" FontSize="11"/>
                                            </StackPanel>
                                            <Button x:Name="HotkeyBtn" Grid.Column="1" Content="Alt + K" Width="140" Height="32" Background="#121414" Foreground="{DynamicResource AccentBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" Click="HotkeyBtn_Click" FontWeight="Bold" Cursor="Hand" RenderTransformOrigin="0.5,0.5">
                                                <Button.RenderTransform>
                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                </Button.RenderTransform>
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="Bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="Bdr" Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                                                                            <Trigger.EnterActions>
                                                                                <BeginStoryboard Storyboard="{StaticResource HoverScaleIn}"/>
                                                                            </Trigger.EnterActions>
                                                                            <Trigger.ExitActions>
                                                                                <BeginStoryboard Storyboard="{StaticResource HoverScaleOut}"/>
                                                                            </Trigger.ExitActions>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>

                                        <!-- Launch on Startup Toggle -->
                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="RUN ON STARTUP" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Launch Wisp automatically in the system tray on startup." Foreground="#B9CACB" FontSize="11"/>
                                            </StackPanel>
                                            <CheckBox x:Name="StartupCheck" Grid.Column="1" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}"/>
                                        </Grid>

                                    </StackPanel>
                                </Border>

                                <!-- Recording Mode Section -->
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <TextBlock Text="&#xE7FC;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Recording Mode" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Mode selector -->
                                        <StackPanel Margin="0,0,0,4">
                                            <TextBlock Text="WHEN TO RECORD" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="RecordingModeCombo" Height="32" Background="#121414" Foreground="#E2E2E2" BorderBrush="#3B494B" SelectionChanged="RecordingModeCombo_SelectionChanged">
                                                <ComboBoxItem Content="Auto-detect games (recommended)"/>
                                                <ComboBoxItem Content="Always on (record whenever Wisp is open)"/>
                                                <ComboBoxItem Content="Manual (only when I start it)"/>
                                            </ComboBox>
                                            <TextBlock Text="Auto-detect keeps Instant Replay off on the desktop and starts recording the moment a game is in focus - so it never wastes resources when you're not playing." Foreground="#B9CACB" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Auto-detect options (shown only in Auto mode) -->
                                        <StackPanel x:Name="AutoDetectPanel" Visibility="Collapsed">
                                            <Border Height="1" Background="#3B494B" Margin="0,16,0,4"/>

                                            <!-- Import installed games -->
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <TextBlock Text="IMPORT INSTALLED GAMES" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="Recognize games installed through Steam, Epic and GOG instantly. Fully offline - Wisp just reads the launchers' own lists on your PC." Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <CheckBox x:Name="ImportGamesCheck" Grid.Column="1" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}"/>
                                            </Grid>

                                            <!-- Always record list -->
                                            <StackPanel Margin="0,15,0,0">
                                                <TextBlock Text="ALWAYS RECORD THESE APPS" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                                <Border Background="#121414" CornerRadius="6" BorderBrush="#3B494B" BorderThickness="1" MinHeight="34">
                                                    <TextBox x:Name="AlwaysRecordTextBox" Background="Transparent" BorderThickness="0" Foreground="#E2E2E2" VerticalAlignment="Center" Margin="10,6,10,6" CaretBrush="{DynamicResource AccentBrush}" FontSize="12" TextWrapping="Wrap" AcceptsReturn="False"/>
                                                </Border>
                                                <TextBlock Text="Comma-separated process names (without .exe). These are always treated as games, even if auto-detect wouldn't catch them." Foreground="#B9CACB" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <!-- Never record list -->
                                            <StackPanel Margin="0,15,0,0">
                                                <TextBlock Text="NEVER RECORD THESE APPS" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                                <Border Background="#121414" CornerRadius="6" BorderBrush="#3B494B" BorderThickness="1" MinHeight="34">
                                                    <TextBox x:Name="NeverRecordTextBox" Background="Transparent" BorderThickness="0" Foreground="#E2E2E2" VerticalAlignment="Center" Margin="10,6,10,6" CaretBrush="{DynamicResource AccentBrush}" FontSize="12" TextWrapping="Wrap" AcceptsReturn="False"/>
                                                </Border>
                                                <TextBlock Text="Never record these even if they go fullscreen - e.g. browsers and video players. The defaults already cover the common ones." Foreground="#B9CACB" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Video Settings Section -->
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Video Quality" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Resolution -->
                                            <StackPanel Grid.Column="0" Margin="0,0,10,15">
                                                <TextBlock Text="RESOLUTION" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="ResolutionCombo" Height="32"/>
                                                <TextBlock Text="Native keeps your monitor's size; pick a preset to downscale and save space." Foreground="#B9CACB" FontSize="9" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <!-- Framerate -->
                                            <StackPanel Grid.Column="1" Margin="10,0,0,15">
                                                <TextBlock Text="FRAMERATE" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                                <ComboBox x:Name="FpsCombo" Height="32"/>
                                                <TextBlock Text="Frames per second to capture. 60 is smooth; higher needs a stronger PC." Foreground="#B9CACB" FontSize="9" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Quality Presets -->
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="VIDEO QUALITY PRESET" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="QualityCombo" Height="32" Background="#121414" Foreground="#E2E2E2" BorderBrush="#3B494B">
                                                <ComboBoxItem Content="Low (Small files, lower bitrate)"/>
                                                <ComboBoxItem Content="Medium (Balanced quality/size)"/>
                                                <ComboBoxItem Content="High (Lossless-like quality, high bitrate)"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- Recording GPU -->
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="RECORDING GPU (ENCODER)" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="GpuCombo" Height="32" Background="#121414" Foreground="#E2E2E2" BorderBrush="#3B494B"/>
                                            <TextBlock Text="With two GPUs, encode on the one that ISN'T running your game (usually the integrated GPU) to reduce in-game slowdown." Foreground="#B9CACB" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Record Monitor -->
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="RECORD MONITOR" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="RecordMonitorCombo" Height="32" Background="#121414" Foreground="#E2E2E2" BorderBrush="#3B494B"/>
                                            <TextBlock Text="Which screen to capture. Auto follows the monitor your game is on - and moves with it if you drag the game to another screen." Foreground="#B9CACB" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Instant Replay Length Slider -->
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <TextBlock Text="INSTANT REPLAY LENGTH" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Left"/>
                                                <TextBlock x:Name="BufferValueText" Text="30s" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="BufferSlider" Minimum="10" Maximum="600" Value="30" SmallChange="5" LargeChange="30" IsSnapToTickEnabled="True" TickFrequency="5" ValueChanged="BufferSlider_ValueChanged" Height="24"/>
                                            <Grid Margin="0,4,0,0">
                                                <TextBlock Text="10s" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Left"/>
                                                <TextBlock Text="10 min" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <TextBlock Text="How many seconds Wisp keeps ready to clip. A longer replay uses more RAM and disk." Foreground="#B9CACB" FontSize="9" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Clip Chaining -->
                                        <Border BorderBrush="#3B494B" BorderThickness="0,1,0,0" Margin="0,16,0,0" Padding="0,16,0,0">
                                            <StackPanel>
                                                <Grid Margin="0,0,0,6">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                        <TextBlock Text="CLIP CHAINING" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <CheckBox x:Name="ChainingCheck" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}" Checked="ChainingCheck_Changed" Unchecked="ChainingCheck_Changed"/>
                                                </Grid>
                                                <TextBlock Text="Tap the clip hotkey again within the window and Wisp stitches the overlapping moment into one longer clip - with a marker at each tap - instead of separate files." Foreground="#B9CACB" FontSize="9" Margin="0,0,0,10" TextWrapping="Wrap"/>

                                                <StackPanel x:Name="ChainWindowPanel">
                                                    <Grid Margin="0,0,0,6">
                                                        <TextBlock Text="CHAIN WINDOW" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Left"/>
                                                        <TextBlock x:Name="ChainWindowValueText" Text="12s" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                    <Slider x:Name="ChainWindowSlider" Minimum="3" Maximum="60" Value="20" SmallChange="1" LargeChange="5" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="ChainWindowSlider_ValueChanged" Height="24"/>
                                                    <Grid Margin="0,4,0,0">
                                                        <TextBlock Text="3s" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Left"/>
                                                        <TextBlock x:Name="ChainWindowMaxLabel" Text="60s" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                    <TextBlock Text="How long after a tap another tap still extends the same clip. Capped at the replay length so the moments always overlap." Foreground="#B9CACB" FontSize="9" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>

                                    </StackPanel>
                                </Border>

                                <!-- Advanced Encoding Section -->
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Advanced" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Fine-grained control over how clips are encoded. The defaults play everywhere - only change these if you know you want to." Foreground="#B9CACB" FontSize="11" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                        <!-- Video Codec -->
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="VIDEO CODEC" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="VideoCodecCombo" Height="32" Background="#121414" Foreground="#E2E2E2" BorderBrush="#3B494B" SelectionChanged="VideoCodecCombo_SelectionChanged">
                                                <ComboBoxItem Content="H.264 / AVC (most compatible)"/>
                                                <ComboBoxItem Content="H.265 / HEVC (smaller files)"/>
                                                <ComboBoxItem Content="AV1 (best compression, newest GPUs)"/>
                                            </ComboBox>
                                            <TextBlock x:Name="VideoCodecHint" Foreground="#B9CACB" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Custom Bitrate -->
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="CUSTOM BITRATE" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Override the quality preset with an exact bitrate target." Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <CheckBox x:Name="CustomBitrateCheck" Grid.Column="1" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}" Checked="CustomBitrateCheck_Changed" Unchecked="CustomBitrateCheck_Changed"/>
                                        </Grid>
                                        <StackPanel x:Name="CustomBitratePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                            <Grid Margin="0,0,0,6">
                                                <TextBlock Text="TARGET BITRATE" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Left"/>
                                                <TextBlock x:Name="CustomBitrateValueText" Text="6 Mbps" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="CustomBitrateSlider" Minimum="1" Maximum="150" Value="6" SmallChange="1" LargeChange="10" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="CustomBitrateSlider_ValueChanged" Height="24"/>
                                            <Grid Margin="0,4,0,0">
                                                <TextBlock Text="1 Mbps" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Left"/>
                                                <TextBlock Text="150 Mbps" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <TextBlock Text="Higher bitrate = better quality and bigger files. Applies to whichever encoder is active (NVENC / AMF / Quick Sync / CPU)." Foreground="#B9CACB" FontSize="9" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Kill Detection Section -->
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,4">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="&#xF272;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Kill Detection" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <CheckBox x:Name="KillDetectionCheck" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}" Checked="KillDetectionCheck_Changed" Unchecked="KillDetectionCheck_Changed"/>
                                        </Grid>
                                        <TextBlock Text="Detects your kills in supported games and marks them on the clip timeline. Uses only official game APIs and screen sampling - nothing ever touches the game itself, so it's anti-cheat safe." Foreground="#B9CACB" FontSize="11" Margin="0,0,0,4" TextWrapping="Wrap"/>

                                        <StackPanel x:Name="KillDetectionPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                            <!-- Per-game toggles -->
                                            <TextBlock Text="GAMES" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>

                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="League of Legends" Foreground="#E2E2E2" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                <CheckBox x:Name="KillLolCheck" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Counter-Strike 2" Foreground="#E2E2E2" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                                                <CheckBox x:Name="KillCs2Check" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}" Checked="KillCs2Check_Changed" Unchecked="KillCs2Check_Changed"/>
                                            </Grid>

                                            <!-- CS2 GSI sub-panel: config install status + port -->
                                            <StackPanel x:Name="KillCs2Panel" Visibility="Collapsed" Margin="16,0,0,10">
                                                <Grid Margin="0,0,0,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="GSI PORT" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,4"/>
                                                        <Border Background="#121414" CornerRadius="6" BorderBrush="#3B494B" BorderThickness="1" Height="30" Width="90">
                                                            <TextBox x:Name="Cs2GsiPortBox" Background="Transparent" BorderThickness="0" Foreground="#E2E2E2" VerticalAlignment="Center" Margin="10,0,10,0" CaretBrush="{DynamicResource AccentBrush}" FontSize="12"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                                        <TextBlock Text="CS2 CONFIG" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,4"/>
                                                        <Button x:Name="LocateCs2Btn" Content="Locate CS2 folder" Height="30" Background="#3B494B" Foreground="#E2E2E2" BorderBrush="#3B494B" BorderThickness="1" Click="LocateCs2Btn_Click" Cursor="Hand" FontSize="11" HorizontalAlignment="Left" Padding="12,0">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="Bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Bdr" Property="Background" Value="#4C5E60"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                                <TextBlock x:Name="Cs2GsiStatusText" Text="" Foreground="#B9CACB" FontSize="10" TextWrapping="Wrap"/>
                                                <TextBlock Text="CS2 reports kills through Valve's official Game State Integration: saving with this game enabled installs a small config file into CS2's cfg folder (that's the whole integration)." Foreground="#B9CACB" FontSize="9" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <Grid Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                    <TextBlock Text="Valorant" Foreground="#E2E2E2" FontSize="12" VerticalAlignment="Center"/>
                                                    <Border BorderBrush="#3B494B" BorderThickness="1" CornerRadius="3" Padding="4,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="EXPERIMENTAL" Foreground="#B9CACB" FontSize="8" FontWeight="Bold" FontFamily="{StaticResource FontMono}"/>
                                                    </Border>
                                                </StackPanel>
                                                <CheckBox x:Name="KillValorantCheck" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,8">
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                    <TextBlock Text="Overwatch 2" Foreground="#E2E2E2" FontSize="12" VerticalAlignment="Center"/>
                                                    <Border BorderBrush="#3B494B" BorderThickness="1" CornerRadius="3" Padding="4,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="EXPERIMENTAL" Foreground="#B9CACB" FontSize="8" FontWeight="Bold" FontFamily="{StaticResource FontMono}"/>
                                                    </Border>
                                                </StackPanel>
                                                <CheckBox x:Name="KillOverwatchCheck" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}"/>
                                            </Grid>
                                            <TextBlock Text="League and CS2 use each game's official local API - reliable. Valorant and Overwatch 2 have no kill API, so Wisp watches the kill banner on screen instead - expect occasional misses; run the game in Borderless for best results." Foreground="#B9CACB" FontSize="9" Margin="0,0,0,4" TextWrapping="Wrap"/>

                                            <!-- What happens on a kill -->
                                            <Border BorderBrush="#3B494B" BorderThickness="0,1,0,0" Margin="0,10,0,0" Padding="0,14,0,0">
                                                <StackPanel>
                                                    <Grid Margin="0,0,0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                            <TextBlock Text="TIMELINE MARKERS" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                            <TextBlock Text="Saved clips get a red marker at every kill they cover - jump straight to the action in the player." Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                        <CheckBox x:Name="KillMarkersCheck" Grid.Column="1" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}"/>
                                                    </Grid>

                                                    <Grid Margin="0,12,0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                            <TextBlock Text="AUTO-CLIP ON KILL" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                            <TextBlock Text="Automatically saves a clip a few seconds after each kill - no hotkey needed. With clip chaining on, back-to-back kills become one longer clip." Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                        <CheckBox x:Name="KillAutoClipCheck" Grid.Column="1" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}" Checked="KillAutoClipCheck_Changed" Unchecked="KillAutoClipCheck_Changed"/>
                                                    </Grid>

                                                    <StackPanel x:Name="KillAutoClipPanel" Visibility="Collapsed" Margin="0,10,0,0">
                                                        <Grid Margin="0,0,0,6">
                                                            <TextBlock Text="DELAY AFTER KILL" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Left"/>
                                                            <TextBlock x:Name="KillAutoClipDelayValueText" Text="3s" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                        <Slider x:Name="KillAutoClipDelaySlider" Minimum="0" Maximum="10" Value="3" SmallChange="1" LargeChange="2" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="KillAutoClipDelaySlider_ValueChanged" Height="24"/>
                                                        <Grid Margin="0,4,0,0">
                                                            <TextBlock Text="0s" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Left"/>
                                                            <TextBlock Text="10s" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                        <TextBlock Text="How long to keep recording after the kill before the clip is saved, so the aftermath makes it in." Foreground="#B9CACB" FontSize="9" Margin="0,6,0,10" TextWrapping="Wrap"/>

                                                        <Grid Margin="0,0,0,6">
                                                            <TextBlock Text="COOLDOWN BETWEEN AUTO-CLIPS" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Left"/>
                                                            <TextBlock x:Name="KillAutoClipCooldownValueText" Text="15s" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                        <Slider x:Name="KillAutoClipCooldownSlider" Minimum="5" Maximum="60" Value="15" SmallChange="1" LargeChange="5" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="KillAutoClipCooldownSlider_ValueChanged" Height="24"/>
                                                        <Grid Margin="0,4,0,0">
                                                            <TextBlock Text="5s" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Left"/>
                                                            <TextBlock Text="60s" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                        <TextBlock Text="Only used while clip chaining is OFF - with chaining on, rapid kills extend one clip instead." Foreground="#B9CACB" FontSize="9" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                                    </StackPanel>

                                                    <Grid Margin="0,12,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                            <TextBlock Text="DIAGNOSTIC MODE" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                            <TextBlock Text="Saves detection snapshots for the experimental games to %APPDATA%\Wisp\kill-detect-debug, for tuning. Leave off normally." Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                        <CheckBox x:Name="KillDiagCheck" Grid.Column="1" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Output & Storage Section -->
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Output &amp; Storage" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Filename Template -->
                                        <StackPanel Margin="0,0,0,15">
                                            <TextBlock Text="FILENAME TEMPLATE" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                            <Border Background="#121414" CornerRadius="6" BorderBrush="#3B494B" BorderThickness="1" Height="34">
                                                <TextBox x:Name="FilenameTemplateBox" Background="Transparent" BorderThickness="0" Foreground="#E2E2E2" VerticalAlignment="Center" Margin="10,0,10,0" CaretBrush="{DynamicResource AccentBrush}" FontSize="12"/>
                                            </Border>
                                            <TextBlock Text="Available variables: {Game}, {Date}, {Time}. E.g. {Game}_{Date}_{Time}" Foreground="#B9CACB" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Auto-delete / storage limits moved to the Storage tab -->
                                        <Border Background="#15191A" BorderBrush="#2A3435" BorderThickness="1" CornerRadius="6" Padding="12,10">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xEDA2;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,9,0"/>
                                                <TextBlock Text="Auto-delete old clips and storage limits now live in the Storage tab." Foreground="#B9CACB" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Notifications Section -->
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Notifications" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Notification Position -->
                                        <TextBlock Text="NOTIFICATION POSITION" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Monitor" Foreground="#B9CACB" FontSize="9" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="NotifMonitorCombo" Height="32" Background="#121414" Foreground="#E2E2E2" BorderBrush="#3B494B"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                                <TextBlock Text="Visual Positioning" Foreground="#B9CACB" FontSize="9" Margin="0,0,0,4"/>
                                                <Button x:Name="VisualNotifPosBtn" Content="Set Position Visually" Height="32" Background="#3B494B" Foreground="#E2E2E2" BorderBrush="#3B494B" BorderThickness="1" Click="VisualNotifPosBtn_Click" Cursor="Hand" FontSize="11" RenderTransformOrigin="0.5,0.5">
                                                    <Button.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Button.RenderTransform>
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="Bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="Bdr" Property="Background" Value="#4C5E60"/>
                                                                                <Trigger.EnterActions>
                                                                                    <BeginStoryboard Storyboard="{StaticResource HoverScaleIn}"/>
                                                                                </Trigger.EnterActions>
                                                                                <Trigger.ExitActions>
                                                                                    <BeginStoryboard Storyboard="{StaticResource HoverScaleOut}"/>
                                                                                </Trigger.ExitActions>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Feedback divider -->
                                        <Separator Background="#282A2B" Height="1" Margin="0,15"/>

                                        <!-- Auto-Record Notification -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
                                                <TextBlock Text="AUTO-RECORD NOTIFICATION" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Show an overlay popup when auto-detect starts or stops recording on its own. Uses the notification position above and never steals focus from your game." Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <CheckBox x:Name="AutoRecordNotifyCheck" Grid.Column="1" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}"/>
                                        </Grid>

                                        <!-- Show Capture Progress -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,15,0">
                                                <TextBlock Text="SHOW CAPTURE PROGRESS" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Show the loading spinner while a clip saves. When off, you get an instant confirmation chime and the save runs in the background - you're only notified again if it fails." Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <CheckBox x:Name="ShowProgressCheck" Grid.Column="1" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}"/>
                                        </Grid>
                                        
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="CAPTURE SOUND FEEDBACK" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Play a sound chime on clip save success or failure." Foreground="#B9CACB" FontSize="11"/>
                                            </StackPanel>
                                            <CheckBox x:Name="CaptureSoundCheck" Grid.Column="1" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}" Checked="CaptureSoundCheck_Changed" Unchecked="CaptureSoundCheck_Changed"/>
                                        </Grid>

                                        <StackPanel x:Name="CaptureSoundVolumePanel" Margin="0,0,0,5">
                                            <Grid Margin="0,0,0,6">
                                                <TextBlock Text="CAPTURE SOUND VOLUME" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Left"/>
                                                <TextBlock x:Name="CaptureSoundVolumeText" Text="70%" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="CaptureSoundVolumeSlider" Minimum="0" Maximum="100" Value="70" ValueChanged="CaptureSoundVolumeSlider_ValueChanged" Height="24"/>
                                            <Grid Margin="0,4,0,0">
                                                <TextBlock Text="0%" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Left"/>
                                                <TextBlock Text="100%" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>

                                    </StackPanel>
                                </Border>

                                <!-- Audio Capture Section -->
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <TextBlock Text="&#xE720;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Audio Capture" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        
                                        <!-- System Game Audio Toggle -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="CAPTURE SYSTEM GAME AUDIO" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Include game sound effects and desktop audio." Foreground="#B9CACB" FontSize="11"/>
                                            </StackPanel>
                                            <CheckBox x:Name="SysAudioCheck" Grid.Column="1" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}"/>
                                        </Grid>

                                        <!-- Microphone Capture Toggle -->
                                        <Grid Margin="0,0,0,15">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="RECORD MICROPHONE" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Capture your microphone voiceover commentary." Foreground="#B9CACB" FontSize="11"/>
                                            </StackPanel>
                                            <CheckBox x:Name="MicCheck" Grid.Column="1" VerticalAlignment="Center" Checked="MicCheck_Changed" Unchecked="MicCheck_Changed" Style="{DynamicResource ToggleSwitchStyle}"/>
                                        </Grid>

                                        <!-- Microphone Device Selection Panel -->
                                        <StackPanel x:Name="MicDevicePanel" Visibility="Collapsed">
                                            <TextBlock Text="MICROPHONE SOURCE DEVICE" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="MicDeviceCombo" Height="32" Background="#121414" Foreground="#E2E2E2" BorderBrush="#3B494B"/>
                                        </StackPanel>

                                        <!-- Social App Audio Toggle -->
                                        <Grid Margin="0,15,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="ISOLATE SOCIAL APP AUDIO" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Capture Discord / Messenger / etc. on its own track, split out from the system/game audio. Shown as a separate waveform you can mix in the player." Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <CheckBox x:Name="SocialAudioCheck" Grid.Column="1" VerticalAlignment="Center" Checked="SocialAudioCheck_Changed" Unchecked="SocialAudioCheck_Changed" Style="{DynamicResource ToggleSwitchStyle}"/>
                                        </Grid>

                                        <!-- Social App Process Names (shown when enabled) -->
                                        <StackPanel x:Name="SocialOptionsPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                            <TextBlock Text="SOCIAL APP PROCESS NAMES" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                            <Border Background="#121414" CornerRadius="6" BorderBrush="#3B494B" BorderThickness="1" MinHeight="34">
                                                <TextBox x:Name="SocialAppsTextBox" Background="Transparent" BorderThickness="0" Foreground="#E2E2E2" VerticalAlignment="Center" Margin="10,6,10,6" CaretBrush="{DynamicResource AccentBrush}" FontSize="12" TextWrapping="Wrap" AcceptsReturn="False"/>
                                            </Border>
                                            <TextBlock Text="Comma-separated process names (without .exe). The first one running is isolated from system audio. Defaults cover Discord, Slack, Teams, Zoom and more." Foreground="#B9CACB" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <!-- Divider -->
                                        <Border Height="1" Background="#3B494B" Margin="0,18,0,4"/>

                                        <!-- System Audio Volume -->
                                        <StackPanel Margin="0,8,0,0">
                                            <Grid Margin="0,0,0,2">
                                                <TextBlock Text="SYSTEM AUDIO VOLUME" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Left"/>
                                                <TextBlock x:Name="SysVolumeValueText" Text="100%" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="SysVolumeSlider" Minimum="0" Maximum="200" Value="100" SmallChange="5" LargeChange="25" IsSnapToTickEnabled="True" TickFrequency="5" ValueChanged="SysVolumeSlider_ValueChanged" Height="24"/>
                                        </StackPanel>

                                        <!-- Microphone Volume -->
                                        <StackPanel Margin="0,10,0,0">
                                            <Grid Margin="0,0,0,2">
                                                <TextBlock Text="MICROPHONE VOLUME" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Left"/>
                                                <TextBlock x:Name="MicVolumeValueText" Text="100%" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="MicVolumeSlider" Minimum="0" Maximum="200" Value="100" SmallChange="5" LargeChange="25" IsSnapToTickEnabled="True" TickFrequency="5" ValueChanged="MicVolumeSlider_ValueChanged" Height="24"/>
                                        </StackPanel>

                                        <!-- Social App Volume -->
                                        <StackPanel Margin="0,10,0,0">
                                            <Grid Margin="0,0,0,2">
                                                <TextBlock Text="SOCIAL APP VOLUME" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Left"/>
                                                <TextBlock x:Name="SocialVolumeValueText" Text="100%" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="SocialVolumeSlider" Minimum="0" Maximum="200" Value="100" SmallChange="5" LargeChange="25" IsSnapToTickEnabled="True" TickFrequency="5" ValueChanged="SocialVolumeSlider_ValueChanged" Height="24"/>
                                        </StackPanel>

                                        <!-- Audio Sync Offset -->
                                        <StackPanel Margin="0,10,0,0">
                                            <Grid Margin="0,0,0,2">
                                                <TextBlock Text="AUDIO SYNC OFFSET" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Left"/>
                                                <TextBlock x:Name="AudioOffsetValueText" Text="0 ms" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="AudioOffsetSlider" Minimum="-500" Maximum="500" Value="0" SmallChange="10" LargeChange="50" IsSnapToTickEnabled="True" TickFrequency="10" ValueChanged="AudioOffsetSlider_ValueChanged" Height="24"/>
                                            <TextBlock Text="Negative = audio earlier · Positive = audio later." Foreground="#B9CACB" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                            <!-- Caution box: a wrong offset CREATES desync, so only touch it to fix audio that is already off. -->
                                            <Border Background="#241E0A" BorderBrush="#FFC53D" BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="0,8,0,0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" Foreground="#FFC53D" FontSize="13" VerticalAlignment="Top" Margin="0,1,9,0"/>
                                                    <TextBlock Grid.Column="1" Foreground="#E8D9A8" FontSize="11" TextWrapping="Wrap"
                                                               Text="Only change this if the audio in your saved clips is actually delayed or ahead of the video. If sound and picture already line up, leave it at 0 ms - a wrong offset will create the desync it's meant to fix."/>
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                        <!-- Audio Quality -->
                                        <StackPanel Margin="0,18,0,0">
                                            <TextBlock Text="AUDIO QUALITY" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="AudioQualityCombo" Height="32" Background="#121414" Foreground="#E2E2E2" BorderBrush="#3B494B">
                                                <ComboBoxItem Content="Standard (192 kbps AAC)"/>
                                                <ComboBoxItem Content="High (256 kbps AAC)"/>
                                                <ComboBoxItem Content="Studio (320 kbps AAC)"/>
                                            </ComboBox>
                                            <TextBlock Text="Bitrate for recorded clips, the in-app preview, and exports. Higher is crisper for mic &amp; game audio, with slightly larger files." Foreground="#B9CACB" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>

                                    </StackPanel>
                                </Border>

                                <!-- Voice Trigger Section -->
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <TextBlock Text="&#xF24C;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Voice-Activated Clipping" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Enable toggle -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="SAY A PHRASE TO CLIP" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                <TextBlock Text="A built-in, fully offline speech engine saves a clip when you say your phrase. Off by default; listens only while Instant Replay is active." Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <CheckBox x:Name="VoiceTriggerCheck" Grid.Column="1" VerticalAlignment="Center" Checked="VoiceTriggerCheck_Changed" Unchecked="VoiceTriggerCheck_Changed" Style="{DynamicResource ToggleSwitchStyle}"/>
                                        </Grid>

                                        <!-- Language + phrase (shown when enabled) -->
                                        <StackPanel x:Name="VoicePhrasePanel" Visibility="Collapsed" Margin="0,15,0,0">
                                            <TextBlock Text="RECOGNITION LANGUAGE" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                            <ComboBox x:Name="VoiceLangCombo" Height="34" Background="#121414" Foreground="#E2E2E2" BorderBrush="#3B494B" SelectionChanged="VoiceLangCombo_SelectionChanged">
                                                <ComboBoxItem Content="English" Tag="en"/>
                                                <ComboBoxItem Content="Polish" Tag="pl"/>
                                                <ComboBoxItem Content="Spanish" Tag="es"/>
                                                <ComboBoxItem Content="French" Tag="fr"/>
                                                <ComboBoxItem Content="German" Tag="de"/>
                                            </ComboBox>

                                            <!-- Action Button for missing model -->
                                            <Button x:Name="VoiceDownloadBtn" Margin="0,8,0,0" Height="28" Style="{StaticResource PremiumSecondaryButtonStyle}" Foreground="#E2E2E2" Click="VoiceDownloadBtn_Click" Visibility="Collapsed">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Path Data="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Download Model" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- Download Progress -->
                                            <StackPanel x:Name="VoiceDownloadPanel" Visibility="Collapsed" Margin="0,5,0,0">
                                                <TextBlock x:Name="VoiceDownloadText" Text="Downloading model..." Foreground="#B9CACB" FontSize="11" Margin="0,0,0,4"/>
                                                <ProgressBar x:Name="VoiceDownloadProgress" Height="4" Minimum="0" Maximum="100" Value="0" Foreground="{DynamicResource AccentBrush}" Background="#1A1E1E" BorderThickness="0"/>
                                            </StackPanel>

                                            <!-- Phrase Input (only visible if model is downloaded) -->
                                            <StackPanel x:Name="VoicePhraseInputPanel" Margin="0,12,0,0">
                                                <TextBlock Text="TRIGGER PHRASE" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,6"/>
                                                <Border Background="#121414" CornerRadius="6" BorderBrush="#3B494B" BorderThickness="1" Height="34">
                                                    <TextBox x:Name="VoicePhraseBox" Background="Transparent" BorderThickness="0" Foreground="#E2E2E2" VerticalAlignment="Center" Margin="10,0,10,0" CaretBrush="{DynamicResource AccentBrush}" FontSize="12"/>
                                                </Border>
                                                <TextBlock Text="Type your phrase in the selected language. Everyday words work best; if it isn't detected, try simpler ones." Foreground="#B9CACB" FontSize="10" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- About & Credits Section -->
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="About &amp; Credits" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <TextBlock Foreground="#E2E2E2" FontSize="12" Margin="0,0,0,2">
                                            <Run Text="Wisp" FontWeight="Bold"/><Run Text=" - a lightweight game clip recorder."/>
                                        </TextBlock>
                                        <TextBlock Foreground="#E2E2E2" FontSize="12" Margin="0,0,0,2" TextWrapping="Wrap">
                                            <Run Text="Made by "/><Hyperlink NavigateUri="https://minimalpulse.com" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}"><Run Text="MinimalPulse"/></Hyperlink><Run Text=" - minimal by name, precise by nature."/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding AppVersionText, RelativeSource={RelativeSource AncestorType=Window}, StringFormat=Version {0}}" Foreground="#B9CACB" FontSize="10" FontFamily="{StaticResource FontMono}" Margin="0,0,0,14"/>

                                        <TextBlock Text="BUILT WITH OPEN SOURCE" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,8"/>

                                        <!-- FFmpeg (GPL - most prominent) -->
                                        <TextBlock Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10">
                                            <Run Text="Recording, trimming and export are powered by "/><Hyperlink NavigateUri="https://ffmpeg.org" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}"><Run Text="FFmpeg"/></Hyperlink><Run Text=" 8.1.1, (c) 2000-2026 the FFmpeg developers, used unmodified under the "/><Hyperlink NavigateUri="https://www.gnu.org/licenses/gpl-3.0.html" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}"><Run Text="GNU GPL v3"/></Hyperlink><Run Text=". Corresponding source: "/><Hyperlink NavigateUri="https://www.gyan.dev/ffmpeg/builds/" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}"><Run Text="gyan.dev"/></Hyperlink><Run Text="."/>
                                        </TextBlock>

                                        <!-- Permissive deps -->
                                        <TextBlock Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,12">
                                            <Run Text="Also built with "/><Hyperlink NavigateUri="https://github.com/alphacep/vosk-api" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}"><Run Text="Vosk"/></Hyperlink><Run Text=" (Apache-2.0), "/><Hyperlink NavigateUri="https://github.com/naudio/NAudio" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}"><Run Text="NAudio"/></Hyperlink><Run Text=" (MIT), "/><Hyperlink NavigateUri="https://github.com/hardcodet/wpf-notifyicon" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}"><Run Text="NotifyIcon.Wpf"/></Hyperlink><Run Text=" (MIT), and Microsoft.Data.Sqlite (MIT)."/>
                                        </TextBlock>

                                        <TextBlock>
                                            <Hyperlink Click="OpenNotices_Click" Foreground="{DynamicResource AccentBrush}" FontSize="11"><Run Text="View full third-party notices"/></Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- Sticky Action Footer Buttons -->
                        <Border Grid.Row="1" Background="#121414" BorderBrush="#3B494B" BorderThickness="0,1,0,0" Padding="0,15,0,0" Margin="0,10,0,0">
                            <Grid MaxWidth="700" HorizontalAlignment="Stretch">
                                <Button x:Name="ReRunSetupBtn" Content="Re-run Setup Wizard" Height="36" Padding="15,0" Background="Transparent" Foreground="{DynamicResource AccentBrush}" BorderBrush="#3B494B" BorderThickness="1" Click="ReRunSetupBtn_Click" HorizontalAlignment="Left" Style="{StaticResource FlatButtonStyle}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button x:Name="CancelSettingsBtn" Content="Discard" Width="90" Height="36" Background="Transparent" Foreground="#E2E2E2" BorderThickness="0" Click="CancelSettingsBtn_Click" Margin="0,0,12,0" Cursor="Hand" RenderTransformOrigin="0.5,0.5">
                                        <Button.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Button.RenderTransform>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Bdr" Background="{TemplateBinding Background}" CornerRadius="6">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bdr" Property="Background" Value="#3B494B"/>
                                                                    <Trigger.EnterActions>
                                                                        <BeginStoryboard Storyboard="{StaticResource HoverScaleIn}"/>
                                                                    </Trigger.EnterActions>
                                                                    <Trigger.ExitActions>
                                                                        <BeginStoryboard Storyboard="{StaticResource HoverScaleOut}"/>
                                                                    </Trigger.ExitActions>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    
                                    <Button x:Name="SaveSettingsBtn" Content="Save Configuration" Width="150" Height="36" Click="SaveSettingsBtn_Click" Style="{StaticResource PremiumPrimaryButtonStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Storage Grid View -->
                    <Grid x:Name="StorageGrid" Visibility="Collapsed" Margin="20,15,20,15">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel MaxWidth="780" HorizontalAlignment="Center" Margin="0,0,0,20">

                                <!-- ===== Library stats ===== -->
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="14,15" Margin="0,0,6,0">
                                        <StackPanel>
                                            <TextBlock x:Name="StatClipsTotal" Text="0" Foreground="{DynamicResource AccentBrush}" FontFamily="{StaticResource FontMono}" FontSize="25" FontWeight="Bold"/>
                                            <TextBlock Text="CLIPS CAPTURED" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="1" Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="14,15" Margin="6,0,6,0">
                                        <StackPanel>
                                            <TextBlock x:Name="StatClipsMonth" Text="0" Foreground="{DynamicResource AccentBrush}" FontFamily="{StaticResource FontMono}" FontSize="25" FontWeight="Bold"/>
                                            <TextBlock Text="THIS MONTH" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="2" Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="14,15" Margin="6,0,6,0">
                                        <StackPanel>
                                            <TextBlock x:Name="StatHours" Text="0.0h" Foreground="{DynamicResource AccentBrush}" FontFamily="{StaticResource FontMono}" FontSize="25" FontWeight="Bold"/>
                                            <TextBlock Text="OF FOOTAGE" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Column="3" Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="14,15" Margin="6,0,0,0">
                                        <StackPanel>
                                            <TextBlock x:Name="StatUsed" Text="0 GB" Foreground="{DynamicResource AccentBrush}" FontFamily="{StaticResource FontMono}" FontSize="25" FontWeight="Bold"/>
                                            <TextBlock Text="USED BY CLIPS" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- ===== Drive usage ===== -->
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,14">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="&#xEDA2;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Disk usage" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock x:Name="DriveNameText" Text="C:\" Foreground="#B9CACB" FontSize="11" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- proportional used/free bar -->
                                        <Grid Height="12">
                                            <Border Background="#0C0E0E" CornerRadius="6"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition x:Name="DriveUsedCol" Width="3*"/>
                                                    <ColumnDefinition x:Name="DriveFreeCol" Width="1*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Background="{DynamicResource AccentBrush}" CornerRadius="6"/>
                                            </Grid>
                                        </Grid>

                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock x:Name="DriveUsedText" Text="-" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource FontMono}" FontSize="14" FontWeight="SemiBold"/>
                                                <TextBlock Text="USED" Foreground="#B9CACB" FontSize="8.5" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                <TextBlock x:Name="DriveFreeText" Text="-" Foreground="{DynamicResource SuccessBrush}" FontFamily="{StaticResource FontMono}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                                <TextBlock Text="FREE" Foreground="#B9CACB" FontSize="8.5" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,2,0,0" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                <TextBlock x:Name="DriveTotalText" Text="-" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource FontMono}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                                <TextBlock Text="TOTAL" Foreground="#B9CACB" FontSize="8.5" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,2,0,0" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ===== Auto clip deletion ===== -->
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="Auto clip deletion" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Keep your library tidy automatically. Favorited and protected clips are never deleted. Both limits can be on at once." Foreground="#B9CACB" FontSize="11" Margin="0,0,0,16" TextWrapping="Wrap"/>

                                        <!-- Age limit -->
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="DELETE AFTER A SET TIME" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Remove clips older than the chosen number of days." Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <CheckBox x:Name="AgeDeleteCheck" Grid.Column="1" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}" Checked="AgeDeleteCheck_Changed" Unchecked="AgeDeleteCheck_Changed"/>
                                        </Grid>
                                        <StackPanel x:Name="AgeDaysPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                            <Grid Margin="0,0,0,6">
                                                <TextBlock Text="MAX AGE" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Left"/>
                                                <TextBlock x:Name="AgeDaysValueText" Text="30 days" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <Slider x:Name="AgeDaysSlider" Minimum="1" Maximum="365" Value="30" SmallChange="1" LargeChange="7" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="AgeDaysSlider_ValueChanged" Height="24"/>
                                            <Grid Margin="0,4,0,0">
                                                <TextBlock Text="1 day" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Left"/>
                                                <TextBlock Text="365 days" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Right"/>
                                            </Grid>

                                            <!-- Countdown badge toggle (age limit only) -->
                                            <Grid Margin="0,14,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <TextBlock Text="SHOW COUNTDOWN ON CLIPS" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                    <TextBlock Text="Mark library clips with a small &quot;5d left&quot; badge so you can see what's about to be removed." Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <CheckBox x:Name="CountdownBadgeCheck" Grid.Column="1" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}"/>
                                            </Grid>
                                        </StackPanel>

                                        <Border Height="1" Background="#3B494B" Margin="0,16,0,16"/>

                                        <!-- Size budget -->
                                        <Grid Margin="0,0,0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="LIMIT TOTAL STORAGE" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,2"/>
                                                <TextBlock Text="Cap how much disk Wisp's clips may use; oldest clips are removed when full." Foreground="#B9CACB" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <CheckBox x:Name="SizeDeleteCheck" Grid.Column="1" VerticalAlignment="Center" Style="{DynamicResource ToggleSwitchStyle}" Checked="SizeDeleteCheck_Changed" Unchecked="SizeDeleteCheck_Changed"/>
                                        </Grid>
                                        <StackPanel x:Name="SizePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- left: slider -->
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                                                    <Grid Margin="0,0,0,6">
                                                        <TextBlock Text="STORAGE BUDGET" Foreground="#B9CACB" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Left"/>
                                                        <TextBlock x:Name="SizeGbValueText" Text="50 GB" Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                    <Slider x:Name="SizeGbSlider" Minimum="1" Maximum="500" Value="50" SmallChange="1" LargeChange="10" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="SizeGbSlider_ValueChanged" Height="24"/>
                                                    <Grid Margin="0,4,0,0">
                                                        <TextBlock Text="1 GB" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Left"/>
                                                        <TextBlock Text="500 GB" Foreground="#B9CACB" FontSize="9" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                    <TextBlock x:Name="DonutWarnText" Text="" Foreground="{DynamicResource WarningBrush}" FontSize="10.5" Margin="0,10,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                                                </StackPanel>

                                                <!-- right: donut gauge (used vs allocated) -->
                                                <Grid Grid.Column="1" Width="150" Height="150">
                                                    <Ellipse Stroke="#0C0E0E" StrokeThickness="15" Width="132" Height="132"/>
                                                    <Ellipse x:Name="DonutFill" Stroke="{DynamicResource AccentBrush}" StrokeThickness="15" Width="132" Height="132" StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                                                        <Ellipse.RenderTransform>
                                                            <RotateTransform Angle="-90"/>
                                                        </Ellipse.RenderTransform>
                                                    </Ellipse>
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock x:Name="DonutUsedText" Text="0 GB" Foreground="{DynamicResource TextPrimaryBrush}" FontFamily="{StaticResource FontMono}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                                                        <TextBlock x:Name="DonutCapText" Text="of 50 GB" Foreground="#B9CACB" FontFamily="{StaticResource FontMono}" FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Button x:Name="StorageApplyBtn" Content="Apply" Width="150" Height="36" HorizontalAlignment="Right" Click="StorageApplyBtn_Click" Style="{StaticResource PremiumPrimaryButtonStyle}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                </Grid>

                <!-- ================= IN-APP VIDEO PLAYER OVERLAY ================= -->
                <Grid x:Name="PlayerOverlay" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed" Background="#F2121414" Panel.ZIndex="100">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="56" /> <!-- Header -->
                        <RowDefinition Height="*" />  <!-- Video rendering screen -->
                        <RowDefinition Height="96" /> <!-- Waveforms (mic / system / social lanes) -->
                        <RowDefinition Height="60" /> <!-- Playback Controls -->
                    </Grid.RowDefinitions>

                    <!-- Header: Title, Tags, Stats, and Close button -->
                    <Border Grid.Row="0" Background="#16191A" BorderBrush="#2A3435" BorderThickness="0,0,0,1" Padding="18,0,16,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" /> <!-- Left: title + tags -->
                                <ColumnDefinition Width="*" />    <!-- Spacer -->
                                <ColumnDefinition Width="Auto" /> <!-- Right: video stats -->
                                <ColumnDefinition Width="Auto" /> <!-- Close button -->
                            </Grid.ColumnDefinitions>

                            <!-- Left side: clip title, chain pill, tags -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="22" Height="22" CornerRadius="6" Background="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,11,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.4"/>
                                    </Border.Effect>
                                    <Path Data="M0,0 L9,5.5 L0,11 Z" Width="9" Height="11" Stretch="Uniform" Fill="#0A1414" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="1,0,0,0"/>
                                </Border>
                                <TextBlock x:Name="PlayerClipTitle" Text="{Binding Filename}" Foreground="#FFFFFF" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center"/>

                                <!-- Chained-clip pill: shown only for stitched multi-moment clips. -->
                                <Border Margin="10,0,0,0" CornerRadius="9" Padding="8,2,9,2" VerticalAlignment="Center"
                                        Background="{DynamicResource AccentDimBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1"
                                        ToolTip="This clip stitches several moments together. Use the timeline markers to jump between them.">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChained}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding ChainMomentsLabel}" Foreground="{DynamicResource AccentBrush}" FontSize="10.5" FontWeight="Bold" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <Border Width="1" Height="18" Background="#2A3435" Margin="13,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Tags:" Foreground="#B9CACB" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <Button x:Name="PlayerTagsBtn" Height="26" Cursor="Hand" Click="PlayerTagsBtn_Click" VerticalAlignment="Center" Margin="0,0,10,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="TagBtnBorder" Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="13" Padding="10,3,9,3" SnapsToDevicePixels="True">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="&#xE8EC;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                    <TextBlock Text="Assign Tags" Foreground="#E2E2E2" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <Path Data="M 0 0 L 4 4 L 8 0 Z" Fill="#B9CACB" Width="8" Height="4" Stretch="Fill" VerticalAlignment="Center" Margin="7,1,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="TagBtnBorder" Property="Background" Value="#282A2B"/>
                                                    <Setter TargetName="TagBtnBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <ItemsControl x:Name="PlayerTagsItemsControl" ItemsSource="{Binding TagList}" VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding BackgroundBrush}" BorderBrush="{Binding BorderBrush}" BorderThickness="1" CornerRadius="9" Padding="8,2,8,2" Margin="0,0,5,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="{Binding TextBrush}" FontSize="10" FontWeight="SemiBold"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Right side: video stats badges -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                                <!-- Resolution -->
                                <Border Background="#1A1E1E" CornerRadius="5" Padding="7,2,7,2" Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE740;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#6B7C7D" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="StatsResolution" Text="-" Foreground="#B9CACB" FontSize="10" FontWeight="SemiBold" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <!-- File Size -->
                                <Border Background="#1A1E1E" CornerRadius="5" Padding="7,2,7,2" Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#6B7C7D" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="StatsSize" Text="-" Foreground="#B9CACB" FontSize="10" FontWeight="SemiBold" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <!-- FPS -->
                                <Border Background="#1A1E1E" CornerRadius="5" Padding="7,2,7,2" Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="FPS" Foreground="#6B7C7D" FontSize="8" FontWeight="Bold" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="StatsFps" Text="…" Foreground="#B9CACB" FontSize="10" FontWeight="SemiBold" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <!-- Codec -->
                                <Border Background="#1A1E1E" CornerRadius="5" Padding="7,2,7,2" Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE714;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#6B7C7D" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="StatsCodec" Text="…" Foreground="#B9CACB" FontSize="10" FontWeight="SemiBold" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <!-- Bitrate -->
                                <Border Background="#1A1E1E" CornerRadius="5" Padding="7,2,7,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xEC4A;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#6B7C7D" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <TextBlock x:Name="StatsBitrate" Text="…" Foreground="#B9CACB" FontSize="10" FontWeight="SemiBold" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Keep pill (only while auto-deletion is enabled): "Keep" outline -> "Kept" filled. -->
                                <Border Width="1" Height="16" Background="#2A3435" Margin="8,0,8,0" VerticalAlignment="Center"
                                        Visibility="{Binding AutoDeletionActive, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                                <Button x:Name="PlayerProtectBtn" Click="PlayerProtectBtn_Click" Height="28" Cursor="Hand" Background="Transparent" BorderThickness="0"
                                        VerticalAlignment="Center"
                                        ToolTip="Keep this clip (exclude it from auto-deletion). Favorites are always kept."
                                        Visibility="{Binding AutoDeletionActive, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Pill" CornerRadius="14" Padding="9,0,12,0" Background="Transparent" BorderBrush="#3B494B" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Path x:Name="PinIcon" Width="12" Height="12" Stretch="Uniform" StrokeThickness="1.4" StrokeLineJoin="Round"
                                                          Fill="Transparent" Stroke="#B9CACB" VerticalAlignment="Center" Margin="0,0,6,0"
                                                          Data="M12,2 C8.13,2 5,5.13 5,9 C5,14.25 12,22 12,22 C12,22 19,14.25 19,9 C19,5.13 15.87,2 12,2 Z M12,11.5 C10.62,11.5 9.5,10.38 9.5,9 C9.5,7.62 10.62,6.5 12,6.5 C13.38,6.5 14.5,7.62 14.5,9 C14.5,10.38 13.38,11.5 12,11.5 Z"/>
                                                    <TextBlock x:Name="PillText" Text="Keep" Foreground="#B9CACB" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsKept}" Value="True">
                                                    <Setter TargetName="Pill" Property="Background" Value="{DynamicResource AccentDimBrush}"/>
                                                    <Setter TargetName="Pill" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter TargetName="PinIcon" Property="Fill" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter TargetName="PinIcon" Property="Stroke" Value="{DynamicResource AccentBrush}"/>
                                                    <Setter TargetName="PillText" Property="Text" Value="Kept"/>
                                                    <Setter TargetName="PillText" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>

                            <!-- Close button -->
                            <Button x:Name="ClosePlayerBtn" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Width="30" Height="30" Foreground="#B9CACB" Background="Transparent" BorderThickness="0"
                                    Click="ClosePlayerBtn_Click">
                                <Button.Content>
                                    <Path Width="11" Height="11" Stretch="Uniform" Data="M2,2 L14,14 M14,2 L2,14"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </Button.Content>
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="15">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FF3B30"/>
                                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Video Display Grid -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition x:Name="ExportSidebarColumn" Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Video Display Canvas -->
                        <Grid x:Name="VideoPlayerGrid" Grid.Column="0" Background="#000000" MouseLeftButtonDown="VideoCanvas_MouseLeftButtonDown" MouseRightButtonDown="VideoCanvas_MouseRightButtonDown" Cursor="Hand" SizeChanged="VideoPlayerGrid_SizeChanged">
                            <MediaElement x:Name="VideoPlayer" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform" IsHitTestVisible="False"
                                          ScrubbingEnabled="True"
                                          MediaOpened="VideoPlayer_MediaOpened" MediaEnded="VideoPlayer_MediaEnded"/>
                            <!-- Plugin video overlays (picture-in-picture webcam, HUDs, etc.) are hosted here, above
                                 the video. Transparent canvas: empty areas stay click-through to play/pause. -->
                            <Canvas x:Name="PlayerOverlayHost" Background="{x:Null}" ClipToBounds="True"/>

                            <!-- 9:16 vertical-crop chooser: a draggable window with everything outside it dimmed.
                                 Shown only while "Vertical" export is selected; lets the user pick which slice of
                                 the frame the Short/Reel keeps. The scrim is non-hit-test so clicks fall through;
                                 the frame itself captures drags (and stops them toggling play/pause). -->
                            <Canvas x:Name="CropOverlayHost" Background="{x:Null}" ClipToBounds="True" Visibility="Collapsed">
                                <Path x:Name="CropScrim" Fill="#99000000" IsHitTestVisible="False"/>
                                <Border x:Name="CropFrame" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2"
                                        Background="Transparent" Cursor="SizeAll" CornerRadius="2"
                                        MouseLeftButtonDown="CropFrame_MouseLeftButtonDown" MouseMove="CropFrame_MouseMove"
                                        MouseLeftButtonUp="CropFrame_MouseLeftButtonUp">
                                    <Border Background="{DynamicResource AccentBrush}" CornerRadius="3" Padding="5,1"
                                            HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,6,0,0" IsHitTestVisible="False">
                                        <TextBlock Text="9:16" Foreground="#0A1414" FontSize="9" FontWeight="Bold" FontFamily="{StaticResource FontMono}"/>
                                    </Border>
                                </Border>
                            </Canvas>
                        </Grid>

                        <!-- Export Sidebar Panel -->
                        <Border x:Name="ExportSidebar" Grid.Column="1" Width="320" Background="#15191A" BorderBrush="#2A3435" BorderThickness="1,0,0,0" Visibility="Collapsed">
                            <Grid Margin="22,20,22,20">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- Header (fixed) -->
                                    <RowDefinition Height="*"/>    <!-- Scrolling config sections -->
                                    <RowDefinition Height="Auto"/> <!-- Output spec readout (pinned) -->
                                    <RowDefinition Height="Auto"/> <!-- Export action button (pinned) -->
                                </Grid.RowDefinitions>

                                <!-- Header: bold condensed display title + in-panel collapse (reuses the
                                     toolbar Export toggle handler). -->
                                <Grid Margin="0,0,0,22">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="EXPORT" Foreground="#FFFFFF" FontFamily="{StaticResource FontDisplay}" FontStretch="Condensed" FontWeight="Bold" FontSize="27"/>
                                        <TextBlock Text="Render, crop &amp; share your clip" Foreground="#7E8C8D" FontSize="11" Margin="1,-1,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Width="30" Height="30" VerticalAlignment="Top" Style="{StaticResource TransportGhostButtonStyle}" Click="ExportBtn_Click" ToolTip="Close export panel">
                                        <Path Data="M6,4 L14,11 L6,18" Width="11" Height="13" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Button>
                                </Grid>

                                <!-- The config sections scroll when the panel is shorter than their content, so the
                                     OUTPUT readout and Export button below stay pinned and always reachable. -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,6,0">
                                    <StackPanel>

                                <!-- Clip Name -->
                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="CLIP NAME" Style="{StaticResource ExportSectionLabelStyle}"/>
                                    <TextBox x:Name="ExportNameTextBox" Background="#0E1010" BorderBrush="#2A3435" BorderThickness="1" Foreground="#E2E2E2" CaretBrush="{DynamicResource AccentBrush}" Padding="12,10" FontSize="12.5">
                                        <TextBox.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="9"/>
                                            </Style>
                                        </TextBox.Resources>
                                    </TextBox>
                                </StackPanel>
                                
                                <!-- Format / Aspect ratio. The chips keep their settable Background (chip),
                                     Foreground (label) and BorderBrush (frame glyph) so SetExportFormat() can
                                     paint the active/inactive state exactly as before. -->
                                <StackPanel Grid.Row="2" Margin="0,0,0,20">
                                    <TextBlock Text="ASPECT RATIO" Style="{StaticResource ExportSectionLabelStyle}"/>
                                    <Border Background="#0E1010" BorderBrush="#2A3435" BorderThickness="1" CornerRadius="10" Padding="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="FormatLandscapeChip" Grid.Column="0" CornerRadius="7" Padding="0,13" Cursor="Hand"
                                                    Background="{DynamicResource AccentBrush}" MouseLeftButtonUp="FormatLandscape_Click">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border x:Name="FormatLandscapeIcon" Width="30" Height="17" BorderBrush="#0A1414" BorderThickness="1.8" CornerRadius="2.5" HorizontalAlignment="Center" Margin="0,0,0,9"/>
                                                    <TextBlock x:Name="FormatLandscapeText" Text="Landscape" FontSize="11.5" FontWeight="SemiBold" Foreground="#0A1414" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border x:Name="FormatVerticalChip" Grid.Column="1" CornerRadius="7" Padding="0,13" Cursor="Hand" Margin="4,0,0,0"
                                                    Background="Transparent" MouseLeftButtonUp="FormatVertical_Click">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border x:Name="FormatVerticalIcon" Width="14" Height="24" BorderBrush="#8A9A9B" BorderThickness="1.8" CornerRadius="2.5" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                                    <TextBlock x:Name="FormatVerticalText" Text="Vertical" FontSize="11.5" FontWeight="SemiBold" Foreground="#8A9A9B" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border x:Name="FormatCustomChip" Grid.Column="2" CornerRadius="7" Padding="0,13" Cursor="Hand" Margin="4,0,0,0"
                                                    Background="Transparent" MouseLeftButtonUp="FormatCustom_Click">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Border x:Name="FormatCustomIcon" Width="22" Height="22" BorderBrush="#8A9A9B" BorderThickness="1.8" CornerRadius="2.5" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                    <TextBlock x:Name="FormatCustomText" Text="Custom" FontSize="11.5" FontWeight="SemiBold" Foreground="#8A9A9B" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <TextBlock x:Name="FormatHint" Text="Drag the frame on the video to choose the crop." Foreground="#8A9A9B" FontSize="10.5" TextWrapping="Wrap" Margin="2,8,0,0" Visibility="Collapsed"/>

                                    <!-- Custom ratio entry (shown only for the Custom chip): width : height, with quick presets. -->
                                    <StackPanel x:Name="CustomAspectPanel" Visibility="Collapsed" Margin="2,12,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="#0E1010" BorderBrush="#2A3435" BorderThickness="1" CornerRadius="8" Height="38">
                                                <TextBox x:Name="CustomAspectWBox" Text="1" Background="Transparent" BorderThickness="0" Foreground="#E2E2E2"
                                                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center" CaretBrush="{DynamicResource AccentBrush}"
                                                         FontFamily="{StaticResource FontMono}" FontSize="15" MaxLength="5" TextChanged="CustomAspect_TextChanged"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text=":" Foreground="{DynamicResource AccentBrush}" FontSize="19" FontWeight="Bold" VerticalAlignment="Center" Margin="11,0,11,0"/>
                                            <Border Grid.Column="2" Background="#0E1010" BorderBrush="#2A3435" BorderThickness="1" CornerRadius="8" Height="38">
                                                <TextBox x:Name="CustomAspectHBox" Text="1" Background="Transparent" BorderThickness="0" Foreground="#E2E2E2"
                                                         VerticalContentAlignment="Center" HorizontalContentAlignment="Center" CaretBrush="{DynamicResource AccentBrush}"
                                                         FontFamily="{StaticResource FontMono}" FontSize="15" MaxLength="5" TextChanged="CustomAspect_TextChanged"/>
                                            </Border>
                                        </Grid>
                                        <WrapPanel Margin="0,9,0,0">
                                            <Border Background="#15191A" BorderBrush="#2A3435" BorderThickness="1" CornerRadius="6" Padding="9,4" Margin="0,0,6,0" Cursor="Hand" Tag="1:1" MouseLeftButtonUp="AspectPreset_Click">
                                                <TextBlock Text="1:1" Foreground="#B9CACB" FontSize="11" FontFamily="{StaticResource FontMono}"/>
                                            </Border>
                                            <Border Background="#15191A" BorderBrush="#2A3435" BorderThickness="1" CornerRadius="6" Padding="9,4" Margin="0,0,6,0" Cursor="Hand" Tag="4:5" MouseLeftButtonUp="AspectPreset_Click">
                                                <TextBlock Text="4:5" Foreground="#B9CACB" FontSize="11" FontFamily="{StaticResource FontMono}"/>
                                            </Border>
                                            <Border Background="#15191A" BorderBrush="#2A3435" BorderThickness="1" CornerRadius="6" Padding="9,4" Margin="0,0,6,0" Cursor="Hand" Tag="4:3" MouseLeftButtonUp="AspectPreset_Click">
                                                <TextBlock Text="4:3" Foreground="#B9CACB" FontSize="11" FontFamily="{StaticResource FontMono}"/>
                                            </Border>
                                            <Border Background="#15191A" BorderBrush="#2A3435" BorderThickness="1" CornerRadius="6" Padding="9,4" Margin="0,0,6,0" Cursor="Hand" Tag="21:9" MouseLeftButtonUp="AspectPreset_Click">
                                                <TextBlock Text="21:9" Foreground="#B9CACB" FontSize="11" FontFamily="{StaticResource FontMono}"/>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Trim Range: one readout with START | END (labels set by UpdateTrimText) -->
                                <StackPanel Grid.Row="3" Margin="0,0,0,20">
                                    <TextBlock Text="TRIM RANGE" Style="{StaticResource ExportSectionLabelStyle}"/>
                                    <Border Background="#0E1010" BorderBrush="#2A3435" BorderThickness="1" CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center" Margin="0,11">
                                                <TextBlock Text="START" Foreground="#5E6E6F" FontSize="8.5" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                <TextBlock x:Name="TrimStartLabel" Text="0.0s" Foreground="{DynamicResource AccentBrush}" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="{StaticResource FontMono}"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Width="1" Background="#2A3435" Margin="0,10"/>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="0,11">
                                                <TextBlock Text="END" Foreground="#5E6E6F" FontSize="8.5" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                <TextBlock x:Name="TrimEndLabel" Text="31.5s" Foreground="{DynamicResource AccentBrush}" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" FontFamily="{StaticResource FontMono}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                                
                                <!-- Quality / Target size (label set by UpdateExportSizeBounds) -->
                                <StackPanel Grid.Row="4" Margin="0,0,0,20">
                                    <TextBlock Text="QUALITY &amp; SIZE" Style="{StaticResource ExportSectionLabelStyle}"/>
                                    <Border Background="#0E1010" BorderBrush="#2A3435" BorderThickness="1" CornerRadius="10" Padding="14,11">
                                        <StackPanel>
                                            <TextBlock x:Name="ExportTargetLabel" Text="Original (Source Quality)" Foreground="#E2E2E2" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,11"/>
                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Min" Foreground="#5E6E6F" FontSize="9" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                                                <Slider x:Name="ExportTargetSlider" Grid.Column="1" Minimum="10" Maximum="100" Value="100" IsMoveToPointEnabled="True" ValueChanged="ExportTargetSlider_ValueChanged" Margin="10,0"/>
                                                <TextBlock Text="Original" Foreground="#5E6E6F" FontSize="9" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center" Grid.Column="2"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Include: audio mix + plugin overlay burn-in, grouped under one header so they
                                     read as a pair of toggles rather than two competing cards. Each row keeps its
                                     named wrapper - SetExportFormat/UpdateOverlayAvailability dim them via Opacity
                                     and toggle the checkbox/hint exactly as before. -->
                                <StackPanel Grid.Row="5" Margin="0,0,0,20">
                                    <TextBlock Text="INCLUDE" Style="{StaticResource ExportSectionLabelStyle}"/>
                                    <Border Background="#0E1010" BorderBrush="#2A3435" BorderThickness="1" CornerRadius="10" Padding="14,4">
                                        <StackPanel>
                                            <Grid x:Name="ExportAudioSection" Margin="0,11">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <TextBlock Text="Apply audio mix" Foreground="#E2E2E2" FontSize="12.5" FontWeight="SemiBold"/>
                                                    <TextBlock x:Name="ExportAudioHint" Text="Bake your mute &amp; volume changes into the file." Foreground="#7E8C8D" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <CheckBox x:Name="ApplyAudioMixCheck" Grid.Column="1" VerticalAlignment="Center" IsChecked="True" Style="{DynamicResource ToggleSwitchStyle}"/>
                                            </Grid>
                                            <Border Height="1" Background="#1E2627"/>
                                            <Grid x:Name="ExportOverlaySection" Margin="0,11">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <TextBlock Text="Burn in overlays" Foreground="#E2E2E2" FontSize="12.5" FontWeight="SemiBold"/>
                                                    <TextBlock x:Name="ExportOverlayHint" Text="Bake plugin layers (e.g. webcam) into the video." Foreground="#7E8C8D" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <CheckBox x:Name="BurnOverlaysCheck" Grid.Column="1" VerticalAlignment="Center" IsChecked="True" Style="{DynamicResource ToggleSwitchStyle}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                    </StackPanel>
                                </ScrollViewer>

                                <!-- Output spec readout (instrument-style; values set by UpdateExportMetadata) -->
                                <StackPanel Grid.Row="2" Margin="0,0,0,16">
                                    <Border BorderBrush="#2A3435" BorderThickness="0,1,0,0" Padding="0,15,0,0">
                                        <StackPanel>
                                            <TextBlock Text="OUTPUT" Style="{StaticResource ExportSectionLabelStyle}" Margin="0,0,0,10"/>
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Resolution" Style="{StaticResource ExportSpecLabelStyle}"/>
                                                <TextBlock x:Name="ExportResText" Text="Unknown" Style="{StaticResource ExportSpecValueStyle}"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,8">
                                                <TextBlock Text="Format" Style="{StaticResource ExportSpecLabelStyle}"/>
                                                <TextBlock x:Name="ExportFormatText" Text="MP4 (H.264)" Style="{StaticResource ExportSpecValueStyle}"/>
                                            </Grid>
                                            <Grid>
                                                <TextBlock Text="Est. Time" Style="{StaticResource ExportSpecLabelStyle}"/>
                                                <TextBlock x:Name="ExportTimeText" Text="Instant" Foreground="{DynamicResource AccentBrush}" FontSize="11.5" FontWeight="SemiBold" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                
                                <!-- Action Button - solid accent is the commit step (the toolbar Export is the
                                     gateway that opens this panel; this button runs the render). -->
                                <Button x:Name="ExportClipBtn" Grid.Row="3" Height="46" Foreground="#0A1414" Click="ExportClipBtn_Click" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="b" Background="{DynamicResource AccentBrush}" CornerRadius="10">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.42"/>
                                                </Border.Effect>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Path Data="M4,2 L4,14 L20,14 L20,2 Z M4,14 L4,18 L20,18 L20,14 Z M16,16 L18,16"
                                                          Width="13" Height="13" Stretch="Uniform" Stroke="#0A1414" StrokeThickness="1.9"
                                                          Margin="0,0,9,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Export Clip" FontWeight="Bold" FontSize="13.5" VerticalAlignment="Center" Foreground="#0A1414"/>
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Waveform (peaks computed on open; click to seek). Recessed near-black "scope" so the
                         coloured per-source lanes read as drawn on an instrument display. -->
                    <Border Grid.Row="2" Background="#0C0E0E" BorderBrush="#3B494B" BorderThickness="0,1,0,0">
                        <Grid>
                            <Canvas x:Name="WaveformCanvas" Background="Transparent" ClipToBounds="True" Cursor="Hand"
                                    MouseLeftButtonDown="WaveformCanvas_MouseLeftButtonDown" MouseMove="WaveformCanvas_MouseMove"
                                    MouseLeftButtonUp="WaveformCanvas_MouseLeftButtonUp" MouseRightButtonUp="WaveformCanvas_MouseRightButtonUp"
                                    SizeChanged="WaveformCanvas_SizeChanged"/>
                            
                            <!-- Draggable Trim Clamps Overlay -->
                            <Canvas x:Name="TrimCanvas" Background="{x:Null}" ClipToBounds="True" Visibility="Collapsed">
                                <!-- Shaded left area -->
                                <Rectangle x:Name="LeftDimOverlay" Fill="#80080A0A" IsHitTestVisible="False" Width="0"/>
                                <!-- Shaded right area -->
                                <Rectangle x:Name="RightDimOverlay" Fill="#80080A0A" IsHitTestVisible="False" Width="0"/>
                                
                                <!-- Left Clamp. One centred grip on a full-height boundary line reads cleaner than
                                     the old twin-handle look. Fixed 16px width; UpdateTrimUI keeps it fully on-canvas. -->
                                <Thumb x:Name="LeftClamp" Width="16" Cursor="SizeWE" DragStarted="Clamp_DragStarted" DragDelta="LeftClamp_DragDelta" DragCompleted="LeftClamp_DragCompleted">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="Transparent" Width="16">
                                                <Grid>
                                                    <Rectangle Width="2" Fill="{DynamicResource AccentBrush}" HorizontalAlignment="Center" RadiusX="1" RadiusY="1"/>
                                                    <Border Width="14" Height="38" CornerRadius="5" Background="{DynamicResource AccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="9" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.45"/>
                                                        </Border.Effect>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Rectangle Width="1.6" Height="15" Fill="#0A1414" Margin="1.4,0" RadiusX="0.8" RadiusY="0.8"/>
                                                            <Rectangle Width="1.6" Height="15" Fill="#0A1414" Margin="1.4,0" RadiusX="0.8" RadiusY="0.8"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                                
                                <!-- Right Clamp (mirror of the left). -->
                                <Thumb x:Name="RightClamp" Width="16" Cursor="SizeWE" DragStarted="Clamp_DragStarted" DragDelta="RightClamp_DragDelta" DragCompleted="RightClamp_DragCompleted">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="Transparent" Width="16">
                                                <Grid>
                                                    <Rectangle Width="2" Fill="{DynamicResource AccentBrush}" HorizontalAlignment="Center" RadiusX="1" RadiusY="1"/>
                                                    <Border Width="14" Height="38" CornerRadius="5" Background="{DynamicResource AccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <Border.Effect>
                                                            <DropShadowEffect BlurRadius="9" ShadowDepth="0" Color="{DynamicResource AccentColor}" Opacity="0.45"/>
                                                        </Border.Effect>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Rectangle Width="1.6" Height="15" Fill="#0A1414" Margin="1.4,0" RadiusX="0.8" RadiusY="0.8"/>
                                                            <Rectangle Width="1.6" Height="15" Fill="#0A1414" Margin="1.4,0" RadiusX="0.8" RadiusY="0.8"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Canvas>

                            <!-- Right-click a waveform lane to tweak just that track's volume. Opens at the
                                 cursor; its label/slider/mute are tinted to the lane and stay in sync with
                                 the main AUDIO MIX popup (both drive the same live mixer). -->
                            <Popup x:Name="LaneVolumePopup" Placement="MousePoint" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="10" Padding="14" Margin="8">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Color="#000000" Opacity="0.55"/>
                                    </Border.Effect>
                                    <StackPanel Width="216">
                                        <Grid Margin="0,0,0,8">
                                            <TextBlock x:Name="LanePopupLabel" Text="MICROPHONE" FontSize="10" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Left" Foreground="{DynamicResource MicLaneBrush}"/>
                                            <TextBlock x:Name="LanePopupVolText" Text="100%" Foreground="#B9CACB" FontSize="10" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <ToggleButton x:Name="LanePopupMuteToggle" Margin="0,0,10,0" Click="LanePopupMute_Click" ToolTip="Mute track"
                                                          Style="{StaticResource MixMuteToggleStyle}"/>
                                            <Slider x:Name="LanePopupSlider" Width="144" Minimum="0" Maximum="200" Value="100" VerticalAlignment="Center"
                                                    Style="{StaticResource MixSliderStyle}" ValueChanged="LanePopupSlider_ValueChanged"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>

                    <!-- Control Bar (transport deck) -->
                    <Border Grid.Row="3" Background="#1E2020" BorderBrush="#3B494B" BorderThickness="0,1,0,0" Padding="18,0,16,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" /> <!-- Play/Pause/Stop Buttons -->
                                <ColumnDefinition Width="Auto" /> <!-- Current / Total Time -->
                                <ColumnDefinition Width="*" />    <!-- Spacer -->
                                <ColumnDefinition Width="Auto" /> <!-- Fullscreen -->
                                <ColumnDefinition Width="Auto" /> <!-- Volume Icon -->
                                <ColumnDefinition Width="100" />  <!-- Volume Slider -->
                            </Grid.ColumnDefinitions>

                            <!-- Transport deck: the play/pause control is the accent hero; frame-step, stop and
                                 the mixer stay quiet ghost controls so the primary action reads at a glance.
                                 (These buttons must not set a local Foreground - the ghost style recolors the
                                 icon to the accent on hover via the templated Foreground.) -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Frame Step Back -->
                                <Button x:Name="FrameBackBtn" Width="36" Height="36" Margin="0,0,5,0" Style="{StaticResource TransportGhostButtonStyle}" Click="FrameBackBtn_Click" ToolTip="Step 1 Frame Back (Left Arrow)">
                                    <Path Data="M6,5 H8 V19 H6 Z M18,5 L10,12 L18,19 Z" Width="14" Height="14" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Button>
                                <!-- Play/Pause Toggle (hero) -->
                                <Button x:Name="PlayPauseBtn" Width="44" Height="44" Margin="0,0,5,0" Style="{StaticResource TransportPrimaryButtonStyle}" Click="PlayPauseBtn_Click" ToolTip="Play / Pause (Space)">
                                    <Grid>
                                        <!-- A right-pointing triangle's visual mass sits left of its bounding box,
                                             so nudge it right a touch to sit optically centred in the circle. -->
                                        <Path x:Name="PlayIcon" Data="M7,5 L19,12 L7,19 Z" Width="16" Height="16" Stretch="Uniform" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="3,0,0,0" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        <Path x:Name="PauseIcon" Data="M7,5 H10 V19 H7 Z M14,5 H17 V19 H14 Z" Width="15" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                    </Grid>
                                </Button>
                                <!-- Frame Step Forward -->
                                <Button x:Name="FrameForwardBtn" Width="36" Height="36" Margin="0,0,5,0" Style="{StaticResource TransportGhostButtonStyle}" Click="FrameForwardBtn_Click" ToolTip="Step 1 Frame Forward (Right Arrow)">
                                    <Path Data="M6,5 L14,12 L6,19 Z M16,5 H18 V19 H16 Z" Width="14" Height="14" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Button>
                                <!-- Divider between playback transport and the stop / mixer tools -->
                                <Border Width="1" Height="22" Background="#3B494B" Margin="7,0" VerticalAlignment="Center"/>
                                <!-- Stop Button -->
                                <Button x:Name="StopBtn" Width="36" Height="36" Margin="0,0,3,0" Style="{StaticResource TransportGhostButtonStyle}" Click="StopBtn_Click" ToolTip="Stop">
                                    <Path Data="M6,6 H18 V18 H6 Z" Width="12" Height="12" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Button>
                                <!-- Audio Mixer (system / mic) -->
                                <Button x:Name="MixerBtn" Width="36" Height="36" Style="{StaticResource TransportGhostButtonStyle}" Click="MixerBtn_Click" ToolTip="Audio mix (system / mic)">
                                    <Path Data="M5,13 H8 V20 H5 Z M10,7 H13 V20 H10 Z M15,10 H18 V20 H15 Z" Width="16" Height="16" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                </Button>
                            </StackPanel>

                            <!-- Audio mix popup (live system/mic control for clips with separate tracks) -->
                            <Popup x:Name="MixerPopup" PlacementTarget="{Binding ElementName=MixerBtn}" Placement="Top" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="-8" HorizontalOffset="-6">
                                <Border Background="#1E2020" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="10" Padding="14">
                                    <StackPanel Width="250">
                                        <TextBlock Text="AUDIO MIX" Foreground="{DynamicResource AccentBrush}" FontSize="10" FontWeight="Bold" FontFamily="{StaticResource FontMono}" Margin="0,0,0,12"/>

                                        <!-- Order matches the waveform lanes above: Mic -> System -> Social.
                                             Each row's mute icon + slider are tinted to that track's lane hue. -->

                                        <!-- Microphone (amber lane) -->
                                        <StackPanel x:Name="MicMixRow" Margin="0,0,0,14">
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="Microphone" Foreground="#E2E2E2" FontSize="11" HorizontalAlignment="Left"/>
                                                <TextBlock x:Name="MicVolText" Text="100%" Foreground="#B9CACB" FontSize="10" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <ToggleButton x:Name="MicMuteToggle" Margin="0,0,10,0" Click="MicMute_Click" ToolTip="Mute microphone"
                                                              Style="{StaticResource MixMuteToggleStyle}" Foreground="{DynamicResource MicLaneBrush}"/>
                                                <Slider x:Name="MicVolSlider" Width="178" Minimum="0" Maximum="200" Value="100" VerticalAlignment="Center"
                                                        Style="{StaticResource MixSliderStyle}" Foreground="{DynamicResource MicLaneBrush}" ValueChanged="MicVolSlider_ValueChanged"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- System / Game (accent lane) -->
                                        <StackPanel x:Name="SystemMixRow" Margin="0,0,0,14">
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="System / Game" Foreground="#E2E2E2" FontSize="11" HorizontalAlignment="Left"/>
                                                <TextBlock x:Name="SystemVolText" Text="100%" Foreground="#B9CACB" FontSize="10" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <ToggleButton x:Name="SystemMuteToggle" Margin="0,0,10,0" Click="SystemMute_Click" ToolTip="Mute system"
                                                              Style="{StaticResource MixMuteToggleStyle}" Foreground="{DynamicResource AccentBrush}"/>
                                                <Slider x:Name="SystemVolSlider" Width="178" Minimum="0" Maximum="200" Value="100" VerticalAlignment="Center"
                                                        Style="{StaticResource MixSliderStyle}" Foreground="{DynamicResource AccentBrush}" ValueChanged="SystemVolSlider_ValueChanged"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Social app (Discord, Messenger, etc.) (purple lane) -->
                                        <StackPanel x:Name="SocialMixRow">
                                            <Grid Margin="0,0,0,4">
                                                <TextBlock Text="Social app" Foreground="#E2E2E2" FontSize="11" HorizontalAlignment="Left"/>
                                                <TextBlock x:Name="SocialVolText" Text="100%" Foreground="#B9CACB" FontSize="10" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Right"/>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal">
                                                <ToggleButton x:Name="SocialMuteToggle" Margin="0,0,10,0" Click="SocialMute_Click" ToolTip="Mute social app"
                                                              Style="{StaticResource MixMuteToggleStyle}" Foreground="{DynamicResource SocialLaneBrush}"/>
                                                <Slider x:Name="SocialVolSlider" Width="178" Minimum="0" Maximum="200" Value="100" VerticalAlignment="Center"
                                                        Style="{StaticResource MixSliderStyle}" Foreground="{DynamicResource SocialLaneBrush}" ValueChanged="SocialVolSlider_ValueChanged"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock x:Name="MixUnavailableText" Text="This clip was recorded before separate-track mixing, so only the combined audio is available." Foreground="#B9CACB" FontSize="10" TextWrapping="Wrap" Visibility="Collapsed" Margin="0,12,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Popup>

                            <!-- Timeline Display (mono timing readout; text set by the playback tick) -->
                            <TextBlock x:Name="TimeStatusText" Grid.Column="1" Text="00:00 / 00:00" Foreground="#E2E2E2" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,0,12,0" FontFamily="{StaticResource FontMono}"/>

                            <!-- Plugin-contributed player buttons (filled at runtime; see MainWindow.PluginPlayer.cs) -->
                            <StackPanel x:Name="PlayerPluginBar" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="4,0,0,0"/>

                            <!-- Export options button: the gateway that opens the export panel. Accent-tinted
                                 "armed" look so it reads as the player's primary action, while the solid-accent
                                 button inside the panel stays the actual commit. -->
                            <Button x:Name="ExportBtn" Grid.Column="3" Height="34" Margin="10,0,12,0"
                                    Click="ExportBtn_Click" ToolTip="Open export options" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="b" Background="{DynamicResource AccentDimBrush}" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="8" Padding="15,0">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <Path Data="M4,2 L4,14 L20,14 L20,2 Z M4,14 L4,18 L20,18 L20,14 Z M16,16 L18,16"
                                                      Width="14" Height="14" Stretch="Uniform" Stroke="{DynamicResource AccentBrush}" StrokeThickness="1.5"
                                                      VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <TextBlock Text="Export" Foreground="#EAFEFF" FontSize="12.5" FontWeight="Bold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="#0F3537"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Volume control button -->
                            <Button x:Name="MuteBtn" Grid.Column="4" Width="32" Height="30" Margin="10,0,5,0" Background="Transparent" Foreground="#B9CACB" BorderThickness="0" Click="MuteBtn_Click" ToolTip="Mute / Unmute">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Viewbox Width="18" Height="18">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="M3,9 H7 L12,4 V20 L7,15 H3 Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                        <Path x:Name="VolumeWaves" Data="M15,9 A5,5 0 0 1 15,15 M17.5,6.5 A8.5,8.5 0 0 1 17.5,17.5" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Path x:Name="MuteCross" Data="M15,9 L20,14 M20,9 L15,14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.6" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed"/>
                                    </Canvas>
                                </Viewbox>
                            </Button>

                            <!-- Volume Slider -->
                            <Slider x:Name="VolumeSlider" Grid.Column="5" VerticalAlignment="Center" IsMoveToPointEnabled="True"
                                    Minimum="0" Maximum="1" Value="0.8"
                                    ValueChanged="VolumeSlider_ValueChanged"
                                    Margin="5,0,0,0"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Export Progress Overlay -->
                <Grid x:Name="ExportProgressOverlay" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed" Background="#D0121414" Panel.ZIndex="120">
                    <Border Width="300" Height="150" Background="#1E2020" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="10" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="EXPORTING CLIP..." Foreground="{DynamicResource AccentBrush}" FontSize="11" FontWeight="Bold" FontFamily="{StaticResource FontMono}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <ProgressBar x:Name="ExportProgressBar" Width="220" Height="6" Background="#121414" Foreground="{DynamicResource AccentBrush}" BorderThickness="0" IsIndeterminate="True" Margin="0,0,0,15"/>
                            <TextBlock x:Name="ExportProgressStatus" Text="Compressing video..." Foreground="#B9CACB" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Post-Export Popup Overlay -->
                <Grid x:Name="ExportSuccessPopup" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed" Background="#C0000000" Panel.ZIndex="110">
                    <Border Width="340" Height="260" Background="#1E2020" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="2" CornerRadius="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                        </Border.Effect>
                        <Grid Margin="20">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/> <!-- Title / Check -->
                                <RowDefinition Height="*"/>    <!-- Card (Thumbnail / Icon) -->
                                <RowDefinition Height="Auto"/> <!-- Instruction -->
                                <RowDefinition Height="Auto"/> <!-- Close Button -->
                            </Grid.RowDefinitions>
                            
                            <!-- Success Header -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <Path Data="M1,5 L4,8 L11,1" Width="14" Height="14" Stretch="Uniform" Stroke="{DynamicResource AccentBrush}" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="CLIP EXPORTED!" Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="Bold" FontFamily="{StaticResource FontMono}" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Draggable/Clickable Card -->
                            <Border Grid.Row="1" x:Name="ExportDragCard" Background="#121414" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Cursor="Hand" Padding="15" Margin="0,5,0,10"
                                    MouseLeftButtonDown="ExportDragCard_MouseLeftButtonDown"
                                    MouseMove="ExportDragCard_MouseMove"
                                    MouseLeftButtonUp="ExportDragCard_MouseLeftButtonUp">
                                <Grid>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <!-- Video file icon -->
                                        <TextBlock Text="&#xE116;" FontFamily="Segoe MDL2 Assets" FontSize="36" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,6">
                                            <TextBlock.Effect>
                                                <DropShadowEffect Color="{DynamicResource AccentColor}" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock x:Name="ExportedFileNameLabel" Text="clip_export.mp4" Foreground="#E2E2E2" FontSize="11" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="NoWrap" MaxWidth="260"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            
                            <!-- Instructions -->
                            <TextBlock Grid.Row="2" Text="Click to play in media player • Drag to other apps to send" Foreground="#B9CACB" FontSize="10" HorizontalAlignment="Center" Margin="0,0,0,15" TextAlignment="Center"/>
                            
                            <!-- Close Button -->
                            <Button x:Name="CloseExportPopupBtn" Grid.Row="3" Content="Dismiss" Height="30" Width="100" Style="{StaticResource PremiumSecondaryButtonStyle}" Click="CloseExportPopupBtn_Click"/>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ================= IN-APP TOAST =================
                     Transient, non-blocking confirmation. Slides up + fades from the bottom-right
                     and auto-dismisses, so simple "done" messages don't interrupt with a modal. -->
                <Border x:Name="ToastHost" Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="130"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,24,24"
                        Background="#F21E2020" BorderBrush="{DynamicResource AccentBrush}" BorderThickness="1" CornerRadius="10"
                        Padding="16,13" MinWidth="240" MaxWidth="380" Visibility="Collapsed" Opacity="0"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="ToastTransform" Y="24"/>
                    </Border.RenderTransform>
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="28" ShadowDepth="6" Opacity="0.55"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ToastIcon" Grid.Column="0" Text="&#xE10B;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="18" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,13,0"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="ToastTitle" Text="Done" Foreground="#E2E2E2" FontWeight="Bold" FontSize="12.5"/>
                            <TextBlock x:Name="ToastMessage" Text="" Foreground="#B9CACB" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
