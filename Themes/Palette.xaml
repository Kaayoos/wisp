<!--
    Central color palette for Wisp. These are the ONLY place app colors should be defined; XAML
    references them via {DynamicResource ...} and code-behind reads the accent through ThemeManager,
    so a single accent swap re-themes the whole app live.

    The accent family is overwritten at runtime by Services/ThemeManager (preset or custom color).
    Everything else is fixed: neutrals keep the dark UI, semantics keep their conventional meaning,
    and the mic/social waveform lanes keep their brand hues. The SYSTEM waveform lane follows the
    accent (handled in code).
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Accent family (runtime-themed; defaults to Wisp Cyan) ===== -->
    <Color x:Key="AccentColor">#00F2FF</Color>
    <Color x:Key="AccentHoverColor">#7DF4FF</Color>
    <SolidColorBrush x:Key="AccentBrush" Color="#00F2FF"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#7DF4FF"/>
    <!-- Subtle accent-tinted fill for hovered/active accent surfaces. -->
    <SolidColorBrush x:Key="AccentDimBrush" Color="#00F2FF" Opacity="0.14"/>
    <!-- Stronger accent wash for COMMITTED surfaces (active nav tab, armed console header).
         Re-themed at runtime by ThemeManager alongside the rest of the accent family. -->
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#00F2FF" Opacity="0.20"/>

    <!-- ===== Neutrals (fixed dark UI) ===== -->
    <Color x:Key="AppBackgroundColor">#121414</Color>
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#121414"/>
    <!-- Deepest inset "well": recessed surfaces (thumbnail beds, search field, hotkey keycap, grooves).
         Darker than the bg so insets read as cut INTO the panel - gives the shell physical depth. -->
    <SolidColorBrush x:Key="AppWellBrush" Color="#0C0E0E"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#1E2020"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="#282A2B"/>
    <!-- Slightly lifted surface for elements that should sit ABOVE the panel (the capture console). -->
    <SolidColorBrush x:Key="SurfaceRaisedBrush" Color="#24282A"/>
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#3B494B"/>
    <!-- Emphasized border for the focal instrument panel + active states. -->
    <SolidColorBrush x:Key="BorderStrongBrush" Color="#4C6063"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E2E2E2"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#B9CACB"/>

    <!-- ===== Semantic (fixed) ===== -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#34D399"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FFC53D"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF4D4D"/>

    <!-- ===== Waveform source lanes (fixed brand hues; system lane follows accent in code) ===== -->
    <Color x:Key="MicLaneColor">#FFB454</Color>
    <Color x:Key="SocialLaneColor">#B98CFF</Color>
    <!-- Brush forms used by the audio-mix icons/sliders so a track's controls match its waveform hue.
         The SYSTEM lane has no fixed brush here: it follows the live accent via {DynamicResource AccentBrush}. -->
    <SolidColorBrush x:Key="MicLaneBrush" Color="#FFB454"/>
    <SolidColorBrush x:Key="SocialLaneBrush" Color="#B98CFF"/>

    <!-- ===== Type system =====
         Wisp's voice is "tactical instrument", so the UI pairs three roles on a contrast axis
         instead of one Segoe everywhere:
           • Display  - Bahnschrift, the DIN-derived industrial sans Windows ships. Used BOLD and
                        CONDENSED for headings and the sidebar nav so they read like spec-sheet /
                        motorsport-timing type. (WPF resolves Bahnschrift's variable weight + width
                        axes here, so FontWeight/FontStretch on it are real, not synthesized.)
           • Mono     - Cascadia Mono for every numeric / status readout (durations, sizes, hotkeys,
                        the capture console). Tabular, precise - the data on an instrument panel.
           • Body     - the framework default (Segoe UI) stays for prose and form labels.
         Each is a fallback chain so a missing face degrades gracefully rather than vanishing. -->
    <FontFamily x:Key="FontDisplay">Bahnschrift, Segoe UI Semibold, Segoe UI</FontFamily>
    <FontFamily x:Key="FontMono">Cascadia Mono, Consolas</FontFamily>

</ResourceDictionary>
