<Window x:Class="Wisp.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Clip" Height="150" Width="360"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Opacity="0" Loaded="Window_Loaded">

    <Border x:Name="RootBorder" Background="#121414" BorderBrush="#3B494B" BorderThickness="1" CornerRadius="8" Padding="15" RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform ScaleX="0.92" ScaleY="0.92"/>
        </Border.RenderTransform>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Header -->
                <RowDefinition Height="*" />    <!-- Input -->
                <RowDefinition Height="Auto" /> <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock x:Name="DialogTitle" Grid.Row="0" Text="Rename Clip" Foreground="#E2E2E2" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

            <!-- Input Box -->
            <Border Grid.Row="1" Background="#1E2020" CornerRadius="4" BorderBrush="#3B494B" BorderThickness="1" Height="30" VerticalAlignment="Center">
                <TextBox x:Name="InputTextBox" Background="Transparent" BorderThickness="0" Foreground="#E2E2E2" 
                          VerticalAlignment="Center" Margin="8,0,8,0" CaretBrush="{DynamicResource AccentBrush}"
                          GotFocus="InputTextBox_GotFocus" KeyDown="InputTextBox_KeyDown"/>
            </Border>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Cancel" Width="80" Height="28" Background="Transparent" Foreground="#B9CACB" 
                        BorderBrush="#3B494B" BorderThickness="1" Click="CancelButton_Click" Margin="0,0,10,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#282A2B"/>
                                    <Setter Property="Foreground" Value="#E2E2E2"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Save" Width="80" Height="28" Background="{DynamicResource AccentBrush}" Foreground="#121414" 
                        BorderThickness="0" FontWeight="Bold" Click="SaveButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
